---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  series: string;
  storyNumber: number;
  totalStories: number;
}

const { title, description, series, storyNumber, totalStories } = Astro.props;
---
<BaseLayout title={title} description={description}>
  <article class="story-page">
    <header class="story-header">
      <p class="eyebrow">{series}</p>
      <h1>{title}</h1>
      <p class="story-count">Story {storyNumber} of {totalStories}</p>
      <p class="lede">{description}</p>
    </header>
    <div class="story-content">
      <slot />
    </div>
  </article>
</BaseLayout>
