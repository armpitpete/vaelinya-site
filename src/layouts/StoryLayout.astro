---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  series: string;
  storyNumber: number;
  totalStories: number;
  heroImage?: string;
  heroImageAlt?: string;
  relatedWorld?: string[];
  relatedLanguage?: string[];
  relatedArtefacts?: string[];
}

const {
  title,
  description,
  series,
  storyNumber,
  totalStories,
  heroImage,
  heroImageAlt,
  relatedWorld = [],
  relatedLanguage = [],
  relatedArtefacts = [],
} = Astro.props;

const site = Astro.site ?? new URL('https://vaelinya.uk');
const canonicalUrl = new URL(Astro.url.pathname, site).toString();

const storyHeroAlt = new Map([
  [1, 'Lina standing on a luminous bridge over silver mist, holding a small wooden recorder.'],
  [2, 'Lina sitting in a wet meadow beneath a small low grey-blue cloud with warm rain falling around her.'],
  [3, 'Lina standing at the entrance of a living maze made of silver stones, dark green vines, and softly glowing leaves.'],
  [4, 'Lina beside a dark still mirror pool ringed with silver reeds and smooth black stones.'],
  [5, 'Lina standing before a pale sleeping tree in a green grove, with a small glowing bud near its roots.'],
  [6, 'Lina standing beside pale reeds and shallow water while glowing music lines move through the air.'],
  [7, 'Lina on a high grass hill beneath twilight, near a small star and a line of glowing path-stones.'],
  [8, 'Lina at the mouth of a mossy cave, with tiny lights and listening-stones leading into the dark.'],
]);

const resolveHeroImage = (src?: string) => {
  if (!src) return undefined;
  return src.trim();
};

const resolvedHeroImage = resolveHeroImage(heroImage);
const resolvedHeroAlt = heroImageAlt ?? storyHeroAlt.get(storyNumber) ?? description;
const storyImageUrl = resolvedHeroImage ? new URL(resolvedHeroImage, site).toString() : undefined;

const labelForLink = (href: string) => {
  const labels = new Map([
    ['/world/', 'Explore the world'],
    ['/world/the-rim/', 'The Rim'],
    ['/world/rimaeri/', 'The Rimaeri'],
    ['/world/the-warm-remembering/', 'The Warm Remembering'],
    ['/language/', 'Learn the language'],
    ['/language/lexicon/', 'Open the lexicon'],
    ['/language/reference/', 'Language reference'],
    ['/artefacts/', 'Discover artefacts'],
    ['/artefacts/symbols/', 'Symbols'],
    ['/artefacts/symbols/navan/', 'NAVAN symbol'],
    ['/artefacts/maps/', 'Maps'],
    ['/artefacts/maps/reader-orientation/', 'Reader orientation map'],
    ['/artefacts/chant-cards/', 'Chant cards'],
    ['/artefacts/story-objects/', 'Story objects'],
    ['/artefacts/printables/', 'Printables'],
  ]);

  return labels.get(href) ?? href;
};

const relatedLinks = [
  ...relatedWorld.map((href) => ({ href, group: 'World' })),
  ...relatedLanguage.map((href) => ({ href, group: 'Language' })),
  ...relatedArtefacts.map((href) => ({ href, group: 'Artefacts' })),
];

const storyJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ShortStory',
  name: title,
  description,
  url: canonicalUrl,
  isPartOf: {
    '@type': 'CreativeWorkSeries',
    name: series,
    url: new URL('/read/lina/', site).toString(),
  },
  position: storyNumber,
  inLanguage: 'en',
  ...(storyImageUrl ? { image: storyImageUrl } : {}),
};
---
<BaseLayout title={title} description={description} image={resolvedHeroImage} jsonLd={storyJsonLd}>
  <article class="story-page">
    <header class="story-header story-header-compact" aria-label={`${series}, story ${storyNumber} of ${totalStories}`}>
      <p class="eyebrow">{series}</p>
      <p class="story-count">Story {storyNumber} of {totalStories}</p>
      {resolvedHeroImage && (
        <figure class="story-hero-image">
          <img src={resolvedHeroImage} alt={resolvedHeroAlt} loading="eager" decoding="async" />
        </figure>
      )}
    </header>
    <div class="story-content">
      <slot />
    </div>
    {relatedLinks.length > 0 && (
      <footer class="story-related">
        <h2>After the story</h2>
        <p>Follow one thread from this story into the wider world, language, or artefacts.</p>
        <div class="link-list">
          {relatedLinks.map((link) => (
            <a href={link.href}>{link.group}: {labelForLink(link.href)}</a>
          ))}
        </div>
        <p><a class="button secondary" href="/read/lina/">Return to Lina’s stories</a></p>
      </footer>
    )}
  </article>
</BaseLayout>

<style>
  .story-page {
    width: min(100% - 2rem, 860px);
    margin-inline: auto;
  }

  .story-header-compact,
  .story-content,
  .story-related {
    width: min(100%, 680px);
    margin-inline: auto;
  }

  .story-hero-image {
    width: min(100%, 680px);
    max-width: 680px;
    margin: 1rem auto 0;
  }

  .story-hero-image img {
    width: 100%;
  }

  .story-content {
    margin-top: 1rem;
  }

  .story-related {
    margin-top: 2.25rem;
  }

  .story-related .link-list {
    width: 100%;
  }

  @media (max-width: 520px) {
    .story-page {
      width: 100%;
    }
  }
</style>
