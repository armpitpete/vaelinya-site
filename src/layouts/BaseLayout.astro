---
import EmailSealIcon from '../components/EmailSealIcon.astro';

interface Props {
  title: string;
  description?: string;
  image?: string;
  noindex?: boolean;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title,
  description = 'Vaelinya is your next adventure.',
  image = '/images/vaelinya-social-card.svg',
  noindex = false,
  jsonLd,
} = Astro.props;

const site = Astro.site ?? new URL('https://vaelinya.uk');
const canonicalUrl = new URL(Astro.url.pathname, site).toString();
const pageTitle = title.includes('Vaelinya') ? title : `${title} | Vaelinya`;
const imageUrl = new URL(image, site).toString();
const jsonLdItems = Array.isArray(jsonLd) ? jsonLd : jsonLd ? [jsonLd] : [];
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex,follow" />}
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:site_name" content="Vaelinya" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={imageUrl} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />

    <title>{pageTitle}</title>
    <link rel="stylesheet" href="/styles/site.css?v=2026-05-20-a11y-01" />
    <link rel="stylesheet" href="/styles/header-glass.css?v=2026-05-24-02" />
    <link rel="stylesheet" href="/styles/visual-system.css?v=2026-05-20-batch-01" />
    <link rel="stylesheet" href="/styles/story-accessibility.css?v=2026-05-20-a11y-01" />
    <link rel="stylesheet" href="/styles/home-hero-image.css?v=2026-05-22-hero-04" />
    {jsonLdItems.map((item) => (
      <script type="application/ld+json" set:html={JSON.stringify(item)} />
    ))}
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to content</a>
    <header class="site-header">
      <nav class="site-nav" aria-label="Main navigation">
        <a class="brand" href="/">Vaelinya</a>
        <div class="nav-links">
          <a href="/start/">Start</a>
          <a href="/read/">Read</a>
          <a href="/world/">World</a>
          <a href="/language/">Language</a>
          <a href="/artefacts/">Artefacts</a>
          <a href="/about/">About</a>
        </div>
      </nav>
    </header>
    <main id="main-content" class="site-main">
      <slot />
    </main>
    <footer class="site-footer">
      <div>
        <p class="footer-mark">Vaelinya is your next adventure.</p>
        <p class="footer-note">Begin with a story, then follow the world, language, and artefacts as they open.</p>
        <p class="footer-note">
          Contact Merrin
          <a
            href="mailto:merrin@merrinworld.uk"
            aria-label="Email Merrin"
            title="Email Merrin"
            style="display:inline-flex; align-items:center; justify-content:center; width:1.9rem; height:1.9rem; margin-left:0.4rem; vertical-align:middle;"
          >
            <EmailSealIcon size={30} />
          </a>
        </p>
      </div>
      <nav class="footer-links" aria-label="Footer navigation">
        <a href="/start/">Start</a>
        <a href="/read/">Read</a>
        <a href="/world/">World</a>
        <a href="/language/">Language</a>
        <a href="/artefacts/">Artefacts</a>
        <a href="/about/">About</a>
        <a
          href="mailto:merrin@merrinworld.uk"
          aria-label="Email Merrin"
          title="Email Merrin"
          style="display:inline-flex; align-items:center; justify-content:center; width:1.9rem; height:1.9rem;"
        >
          <EmailSealIcon size={30} />
        </a>
      </nav>
    </footer>
  </body>
</html>