---
interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Vaelinya is your next adventure.' } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title} | Vaelinya</title>
    <link rel="stylesheet" href="/styles/site.css?v=2026-05-20-type-scale-2" />
    <link rel="stylesheet" href="/styles/visual-system.css?v=2026-05-20-batch-01" />
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to content</a>
    <header class="site-header">
      <nav class="site-nav" aria-label="Main navigation">
        <a class="brand" href="/">Vaelinya</a>
        <div class="nav-links">
          <a href="/start/">Start</a>
          <a href="/read/">Read</a>
          <a href="/world/">World</a>
          <a href="/language/">Language</a>
          <a href="/artefacts/">Artefacts</a>
          <a href="/about/">About</a>
        </div>
      </nav>
    </header>
    <main id="main-content" class="site-main">
      <slot />
    </main>
    <footer class="site-footer">
      <div>
        <p class="footer-mark">Vaelinya is your next adventure.</p>
        <p class="footer-note">Begin with a story, then follow the world, language, and artefacts as they open.</p>
      </div>
      <nav class="footer-links" aria-label="Footer navigation">
        <a href="/start/">Start</a>
        <a href="/read/">Read</a>
        <a href="/world/">World</a>
        <a href="/language/">Language</a>
        <a href="/artefacts/">Artefacts</a>
        <a href="/about/">About</a>
      </nav>
    </footer>
  </body>
</html>
