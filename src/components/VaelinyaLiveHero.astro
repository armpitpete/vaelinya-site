---
const states = {
  dawn: {
    label: "First light",
    line: "First light is touching the river.",
  },
  day: {
    label: "High day",
    line: "Vaelinya is in high day.",
  },
  dusk: {
    label: "Falling light",
    line: "Falling light gathers on the water.",
  },
  night: {
    label: "High moon",
    line: "The two moons are above the river.",
  },
};

function getVaelinyaHomepageState(date = new Date()) {
  const hour = date.getUTCHours();

  if (hour >= 5 && hour < 9) return "dawn";
  if (hour >= 9 && hour < 17) return "day";
  if (hour >= 17 && hour < 21) return "dusk";
  return "night";
}

const initialState = getVaelinyaHomepageState();
const initialReading = states[initialState];
---

<section class="vaelinya-live-hero" data-state={initialState}>
  <div class="vlh-content">
    <p class="vlh-kicker">Vaelinya now</p>
    <h1>Vaelinya</h1>
    <p class="vlh-subtitle">Choose a door. Begin.</p>

    <nav class="vlh-doors" aria-label="Begin exploring Vaelinya">
      <a href="/read/">Stories</a>
      <a href="/world/">World</a>
      <a href="/language/">Language</a>
    </nav>

    <div class="vlh-reading" aria-live="polite">
      <span class="vlh-reading-label">Current reading</span>
      <strong id="vaelinya-live-label">{initialReading.label}</strong>
      <span id="vaelinya-live-line">{initialReading.line}</span>
    </div>
  </div>
</section>

<script>
  const hero = document.querySelector(".vaelinya-live-hero");
  const label = document.querySelector("#vaelinya-live-label");
  const line = document.querySelector("#vaelinya-live-line");
  const previewStates = new Set(["dawn", "day", "dusk", "night"]);

  const states = {
    dawn: {
      label: "First light",
      line: "First light is touching the river.",
    },
    day: {
      label: "High day",
      line: "Vaelinya is in high day.",
    },
    dusk: {
      label: "Falling light",
      line: "Falling light gathers on the water.",
    },
    night: {
      label: "High moon",
      line: "The two moons are above the river.",
    },
  };

  function getPreviewStateFromUrl() {
    const params = new URLSearchParams(window.location.search);
    const previewState = params.get("vaelinya-state");

    if (previewStates.has(previewState)) return previewState;

    return null;
  }

  function getVaelinyaHomepageState(date = new Date()) {
    const hour = date.getUTCHours();

    if (hour >= 5 && hour < 9) return "dawn";
    if (hour >= 9 && hour < 17) return "day";
    if (hour >= 17 && hour < 21) return "dusk";
    return "night";
  }

  function applyVaelinyaHomepageState() {
    if (!hero) return;

    const state = getPreviewStateFromUrl() ?? getVaelinyaHomepageState();
    const reading = states[state];

    hero.dataset.state = state;

    if (label) label.textContent = reading.label;
    if (line) line.textContent = reading.line;
  }

  applyVaelinyaHomepageState();
  setInterval(applyVaelinyaHomepageState, 60_000);
</script>

<style>
  .vaelinya-live-hero {
    --vlh-title: #f8fbff;
    --vlh-text: rgba(248, 251, 255, 0.88);
    --vlh-muted: rgba(248, 251, 255, 0.72);
    --vlh-panel: rgba(5, 12, 32, 0.3);
    --vlh-panel-border: rgba(248, 251, 255, 0.28);
    --vlh-button: rgba(5, 12, 32, 0.26);
    --vlh-button-hover: rgba(248, 251, 255, 0.18);

    position: relative;
    min-height: clamp(520px, 74vh, 820px);
    overflow: hidden;
    isolation: isolate;
    color: var(--vlh-text);
    background: transparent;
  }

  .vaelinya-live-hero[data-state="dawn"] {
    --vlh-title: #fff8f3;
    --vlh-text: rgba(255, 248, 243, 0.9);
    --vlh-muted: rgba(255, 248, 243, 0.76);
    --vlh-panel: rgba(34, 24, 54, 0.24);
    --vlh-panel-border: rgba(255, 248, 243, 0.3);
    --vlh-button: rgba(34, 24, 54, 0.22);
    --vlh-button-hover: rgba(255, 248, 243, 0.2);
  }

  .vaelinya-live-hero[data-state="day"] {
    --vlh-title: #ffffff;
    --vlh-text: rgba(255, 255, 255, 0.92);
    --vlh-muted: rgba(255, 255, 255, 0.8);
    --vlh-panel: rgba(10, 46, 74, 0.24);
    --vlh-panel-border: rgba(255, 255, 255, 0.36);
    --vlh-button: rgba(10, 46, 74, 0.24);
    --vlh-button-hover: rgba(255, 255, 255, 0.24);
  }

  .vaelinya-live-hero[data-state="dusk"] {
    --vlh-title: #fff7ff;
    --vlh-text: rgba(255, 247, 255, 0.91);
    --vlh-muted: rgba(255, 247, 255, 0.76);
    --vlh-panel: rgba(25, 15, 50, 0.28);
    --vlh-panel-border: rgba(255, 247, 255, 0.32);
    --vlh-button: rgba(25, 15, 50, 0.26);
    --vlh-button-hover: rgba(255, 247, 255, 0.2);
  }

  .vaelinya-live-hero[data-state="night"] {
    --vlh-title: #f8fbff;
    --vlh-text: rgba(248, 251, 255, 0.88);
    --vlh-muted: rgba(248, 251, 255, 0.72);
    --vlh-panel: rgba(5, 12, 32, 0.34);
    --vlh-panel-border: rgba(248, 251, 255, 0.28);
    --vlh-button: rgba(5, 12, 32, 0.3);
    --vlh-button-hover: rgba(248, 251, 255, 0.18);
  }

  .vlh-content {
    position: relative;
    z-index: 2;
    max-width: 980px;
    margin: 0 auto;
    padding: clamp(4.5rem, 13vh, 8.5rem) 1.25rem 3.5rem;
    text-align: center;
    text-shadow: 0 2px 18px rgba(0, 0, 0, 0.48);
  }

  .vlh-kicker {
    margin: 0 0 0.75rem;
    color: var(--vlh-muted);
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .vlh-content h1 {
    margin: 0;
    color: var(--vlh-title);
    font-size: clamp(3.2rem, 9vw, 7.8rem);
    line-height: 0.92;
    letter-spacing: -0.045em;
  }

  .vlh-subtitle {
    margin: 1rem 0 1.5rem;
    color: var(--vlh-text);
    font-size: clamp(1.1rem, 2vw, 1.5rem);
  }

  .vlh-doors {
    display: flex;
    justify-content: center;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin: 1.5rem 0 2rem;
  }

  .vlh-doors a {
    color: var(--vlh-title);
    text-decoration: none;
    border: 1px solid var(--vlh-panel-border);
    background: var(--vlh-button);
    border-radius: 999px;
    padding: 0.78rem 1.1rem;
    box-shadow: 0 10px 32px rgba(0, 0, 0, 0.14);
    backdrop-filter: blur(8px);
  }

  .vlh-doors a:hover,
  .vlh-doors a:focus-visible {
    background: var(--vlh-button-hover);
    outline: 2px solid rgba(255, 255, 255, 0.76);
    outline-offset: 3px;
  }

  .vlh-reading {
    display: grid;
    gap: 0.2rem;
    width: min(100%, 540px);
    margin: 0 auto;
    padding: 0.95rem 1rem;
    border: 1px solid var(--vlh-panel-border);
    border-radius: 1.1rem;
    background: var(--vlh-panel);
    box-shadow: 0 18px 46px rgba(0, 0, 0, 0.16);
    backdrop-filter: blur(10px);
  }

  .vlh-reading-label {
    color: var(--vlh-muted);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .vlh-reading strong {
    color: var(--vlh-title);
    font-size: 1.08rem;
  }

  .vlh-reading span:last-child {
    color: var(--vlh-text);
  }

  @media (max-width: 720px) {
    .vaelinya-live-hero {
      min-height: 560px;
      --vlh-panel: rgba(5, 12, 32, 0.44);
      --vlh-button: rgba(5, 12, 32, 0.38);
    }

    .vlh-content {
      padding-top: 4rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .vaelinya-live-hero {
      transition: none !important;
      animation: none !important;
    }
  }
</style>
