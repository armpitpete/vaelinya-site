---
import BaseLayout from '../layouts/BaseLayout.astro';

const {
  title,
  description,
  lede,
  facts,
  accessNote,
  links,
  image,
  caption,
  background,
  variant = 'standard',
  grid = 'minmax(0, 1.35fr) minmax(240px, 0.65fr)',
  artWidth = '320px',
  artDesktopWidth = '300px',
  artTabletWidth = '280px',
  artMobileWidth = '280px',
  artGlow = 'drop-shadow(0 18px 28px rgba(22, 14, 39, 0.2))',
  bgAccent = 'radial-gradient(circle at 50% 24%, rgba(255, 246, 218, 0.18), transparent 34%)',
  bgOverlayLarge = 'linear-gradient(rgba(18, 12, 36, 0.18), rgba(18, 12, 36, 0.44))',
  bgOverlaySmall = 'linear-gradient(rgba(18, 12, 36, 0.2), rgba(18, 12, 36, 0.48))',
} = Astro.props;

const sectionStyle = [
  `--animal-bg-large: url("${background.large}")`,
  `--animal-bg-small: url("${background.small ?? background.large}")`,
  `--animal-bg-accent: ${bgAccent}`,
  `--animal-bg-overlay-large: ${bgOverlayLarge}`,
  `--animal-bg-overlay-small: ${bgOverlaySmall}`,
  `--animal-grid: ${grid}`,
  `--animal-art-width: ${artWidth}`,
  `--animal-art-width-desktop: ${artDesktopWidth}`,
  `--animal-art-width-tablet: ${artTabletWidth}`,
  `--animal-art-width-mobile: ${artMobileWidth}`,
  `--animal-art-glow: ${artGlow}`,
].join('; ');

const pageClasses = [
  'page-section',
  'animal-sheet-page',
  variant === 'wide' && 'animal-sheet-page-wide',
  variant === 'tall' && 'animal-sheet-page-tall',
];
---
<BaseLayout title={title} description={description}>
  <section class:list={pageClasses} style={sectionStyle}>
    <article class="panel animal-sheet">
      <div class="animal-sheet-copy">
        <p class="eyebrow">World · Animals</p>
        <h1>{title}</h1>
        <p class="lede">{lede}</p>

        <dl class="animal-facts">
          {facts.map((fact) => (
            <div>
              <dt>{fact.term}</dt>
              <dd>{fact.detail}</dd>
            </div>
          ))}
        </dl>

        <p class="access-note"><strong>Accessibility note:</strong> {accessNote}</p>

        <nav class="animal-links" aria-label={`Related ${title} pages`}>
          {links.map((link) => (
            <a href={link.href}>{link.label}</a>
          ))}
        </nav>
      </div>

      <figure class="animal-sheet-art">
        <picture>
          <source media="(max-width: 560px)" srcset={image.src512} />
          <source media="(max-width: 900px)" srcset={image.src768} />
          <img
            src={image.src}
            alt={image.alt}
            loading="eager"
            decoding="async"
            width={image.width}
            height={image.height}
          />
        </picture>
        <figcaption>{caption}</figcaption>
      </figure>
    </article>
  </section>

  <style>
    :global(.site-main) {
      max-width: none;
      padding: 0;
    }

    .animal-sheet-page {
      position: relative;
      isolation: isolate;
      overflow: hidden;
      width: 100%;
      max-width: none;
      margin: 0;
      padding: clamp(1.2rem, 3vw, 2.6rem) 1rem;
      border: 0;
      border-radius: 0;
      background: transparent;
      box-shadow: none;
    }

    .animal-sheet-page::before {
      content: "";
      position: absolute;
      inset: 0;
      z-index: -2;
      background-image:
        var(--animal-bg-accent),
        var(--animal-bg-overlay-large),
        var(--animal-bg-large);
      background-repeat: no-repeat;
      background-position: center top;
      background-size: cover;
      pointer-events: none;
    }

    .animal-sheet-page::after {
      content: "";
      position: absolute;
      top: clamp(0.75rem, 2vw, 1.35rem);
      bottom: clamp(0.75rem, 2vw, 1.35rem);
      left: 50%;
      width: min(calc(100% - 2rem), 1180px);
      transform: translateX(-50%);
      z-index: -1;
      border-radius: 1.9rem;
      border: 1px solid rgba(255, 255, 255, 0.66);
      background: rgba(248, 246, 250, 0.12);
      box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.44),
        inset 0 0 0 1px rgba(255, 255, 255, 0.18),
        0 22px 54px rgba(8, 5, 20, 0.34);
      pointer-events: none;
    }

    .animal-sheet {
      position: relative;
      overflow: hidden;
      width: min(100%, 1120px);
      margin-inline: auto;
      display: grid;
      grid-template-columns: var(--animal-grid);
      gap: clamp(1.25rem, 3vw, 2.25rem);
      align-items: start;
      padding: clamp(1.25rem, 3vw, 2.25rem);
      background: linear-gradient(
        180deg,
        rgba(248, 246, 250, 0.92),
        rgba(248, 246, 250, 0.9)
      );
      border: 1px solid rgba(255, 255, 255, 0.62);
      box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.54),
        0 16px 42px rgba(8, 5, 20, 0.28);
      backdrop-filter: blur(6px) saturate(1.03);
      -webkit-backdrop-filter: blur(6px) saturate(1.03);
    }

    .animal-sheet-copy,
    .animal-sheet-art {
      position: relative;
      z-index: 1;
    }

    .animal-sheet .lede {
      max-width: 56ch;
      margin-bottom: 1rem;
    }

    .animal-facts {
      display: grid;
      gap: 0.75rem;
      margin: 1rem 0;
    }

    .animal-facts div {
      padding-block: 0.65rem;
      border-top: 1px solid color-mix(in srgb, var(--ink, #211a33) 14%, transparent);
    }

    .animal-facts dt {
      margin-bottom: 0.18rem;
      font-weight: 800;
      color: var(--ink, #211a33);
    }

    .animal-facts dd {
      margin: 0;
      line-height: 1.55;
    }

    .access-note {
      margin: 1rem 0 0;
      padding: 0.75rem 0;
      border-top: 1px solid color-mix(in srgb, var(--ink, #211a33) 14%, transparent);
      font-size: 0.95rem;
    }

    .animal-links {
      display: flex;
      flex-wrap: wrap;
      gap: 0.55rem;
      margin-top: 0.85rem;
    }

    .animal-links a {
      display: inline-flex;
      align-items: center;
      min-height: 40px;
      padding: 0.55rem 0.85rem;
      border-radius: 999px;
      background: color-mix(in srgb, #fff4be 82%, white);
      border: 1px solid color-mix(in srgb, var(--ink, #211a33) 14%, transparent);
      font-weight: 750;
      text-decoration: none;
    }

    .animal-sheet-art {
      margin: 0;
      padding: 0;
      background: transparent;
      border: 0;
    }

    .animal-sheet-art img {
      display: block;
      width: min(100%, var(--animal-art-width));
      height: auto;
      margin-inline: auto;
      filter: var(--animal-art-glow);
    }

    .animal-sheet-art figcaption {
      max-width: 42ch;
      margin: 0.45rem auto 0;
      color: var(--muted, #574d68);
      font-size: 0.86rem;
      line-height: 1.45;
      text-align: center;
    }

    @media (min-width: 1060px) {
      .animal-facts {
        grid-template-columns: repeat(2, minmax(0, 1fr));
        column-gap: 1.25rem;
        row-gap: 0.4rem;
      }

      .animal-facts div {
        padding-block: 0.55rem;
      }

      .animal-facts div:nth-child(5) {
        grid-column: 1 / -1;
      }

      .animal-sheet-art img {
        width: min(100%, var(--animal-art-width-desktop));
      }
    }

    @media (max-width: 980px) {
      .animal-sheet-page-wide .animal-sheet,
      .animal-sheet-page-tall .animal-sheet {
        grid-template-columns: 1fr;
      }

      .animal-sheet-page-wide .animal-sheet-art,
      .animal-sheet-page-tall .animal-sheet-art {
        order: -1;
      }

      .animal-sheet-page-wide .animal-sheet-art img,
      .animal-sheet-page-tall .animal-sheet-art img {
        width: min(100%, var(--animal-art-width-tablet));
      }
    }

    @media (max-width: 820px) {
      .animal-sheet-page {
        padding: clamp(0.75rem, 3.5vw, 1.2rem) 0.75rem;
      }

      .animal-sheet-page::before {
        background-image:
          var(--animal-bg-accent),
          var(--animal-bg-overlay-small),
          var(--animal-bg-small);
        background-position: center top;
      }

      .animal-sheet-page::after {
        width: min(calc(100% - 1.5rem), 1120px);
        border-radius: 1.35rem;
        border-color: rgba(255, 255, 255, 0.72);
        background: rgba(248, 246, 250, 0.16);
      }

      .animal-sheet {
        grid-template-columns: 1fr;
        background: linear-gradient(
          180deg,
          rgba(248, 246, 250, 0.94),
          rgba(248, 246, 250, 0.92)
        );
        backdrop-filter: blur(6px) saturate(1.03);
        -webkit-backdrop-filter: blur(6px) saturate(1.03);
      }

      .animal-sheet-art {
        order: -1;
      }

      .animal-sheet-art img {
        width: min(100%, var(--animal-art-width-mobile));
      }
    }
  </style>
</BaseLayout>
