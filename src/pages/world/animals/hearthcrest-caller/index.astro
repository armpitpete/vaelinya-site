---
import AnimalPage from '../../../../components/AnimalPage.astro';

const facts = [
  {
    term: 'What it is',
    detail: 'A dinosaur-type elder animal that belongs to warm grassland paths, large-animal care, route memory, and renewal ecology.',
  },
  {
    term: 'Where it lives',
    detail: 'Open warm grasslands, elder-animal paths, resting grounds, violet Orblight meadows, and safe feeding routes watched by smaller creatures.',
  },
  {
    term: 'How to recognise it',
    detail: 'Look for a huge herbivore body, broad careful feet, long neck, warm crest, mouth-light, mossy back growth, and violet Amethyst Orblights nearby.',
  },
  {
    term: 'Sound and movement',
    detail: 'It turns its long neck sideways to see, angles its body away from direct wind, and can walk backwards while calling softly so small creatures move aside.',
  },
  {
    term: 'What it does',
    detail: 'It supports Orblight feeding windows, warm dung nurseries, grassland renewal, heat exchange, and safe movement along ancient elder-animal routes.',
  },
];

const links = [
  { href: '/world/animals/amethyst-orblight/', label: 'Amethyst Orblight' },
  { href: '/world/animals/mosskeep-frog/', label: 'Mosskeep Frog' },
  { href: '/world/animals/', label: 'Animals of Vaelinya' },
];
---
<AnimalPage
  title="Hearthcrest Caller"
  description="A large backward-walking elder herbivore of Vaelinya."
  lede="A huge gentle elder herbivore with a warm glowing crest, mouth-light, broad careful feet, and a low repeated warning call."
  facts={facts}
  accessNote="Hearthcrest Callers are huge gentle crested herbivores with warm mouth-light, broad careful feet, sideways-looking movement, and repeated warning calls."
  links={links}
  image={{
    src: '/assets/images/vaelinya/animals/hearthcrest-caller-v01-1024-q.png',
    src768: '/assets/images/vaelinya/animals/hearthcrest-caller-v01-768-q.png',
    src512: '/assets/images/vaelinya/animals/hearthcrest-caller-v01-512-q.png',
    alt: 'Hearthcrest Caller, a huge gentle dinosaur-type elder herbivore with a glowing warm crest, mouth-light, broad careful feet, a long sideways-turned neck, violet Orblights nearby, and small creatures moving safely around it.',
    width: 1024,
    height: 784,
  }}
  caption="A Hearthcrest Caller turning its long neck sideways while small creatures move safely around it."
  background={{
    large: '/assets/images/vaelinya/animals/hearthcrest-caller-habitat-v01-1920.jpg',
    small: '/assets/images/vaelinya/animals/hearthcrest-caller-habitat-v01-1280.jpg',
  }}
  variant="wide"
  grid="minmax(0, 1.1fr) minmax(380px, 0.9fr)"
  artWidth="500px"
  artDesktopWidth="500px"
  artTabletWidth="440px"
  artMobileWidth="360px"
  artGlow="drop-shadow(0 0 22px rgba(255, 176, 72, 0.24)) drop-shadow(0 22px 34px rgba(22, 14, 39, 0.24))"
  bgAccent="radial-gradient(circle at 28% 20%, rgba(255, 239, 191, 0.28), transparent 34%)"
  bgOverlayLarge="linear-gradient(rgba(35, 15, 36, 0.12), rgba(35, 15, 36, 0.42))"
  bgOverlaySmall="linear-gradient(rgba(35, 15, 36, 0.14), rgba(35, 15, 36, 0.46))"
/>
