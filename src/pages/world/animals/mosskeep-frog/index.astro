---
import AnimalPage from '../../../../components/AnimalPage.astro';

const facts = [
  {
    term: 'What it is',
    detail: 'A small wetland creature of moss, shade, stone, and quiet water.',
  },
  {
    term: 'Where it lives',
    detail: 'Wet bridge stones, shaded pools, old walls, moss beds, tree roots, cave mouths, and damp path edges.',
  },
  {
    term: 'How to recognise it',
    detail: 'Golden eyes, damp stone-coloured feet, blue-green-gold skin, violet flowers, seed capsules, dew-orbs, and fern fronds in the moss on its back.',
  },
  {
    term: 'Sound and movement',
    detail: 'A low wet chirrup, like one drop of water landing in moss. It moves in short careful hops from stone to root to moss patch.',
  },
  {
    term: 'What it does',
    detail: 'It carries moisture, moss spores, fern-specks, wetland seed-life, and small insects between damp places.',
  },
];

const links = [
  { href: '/world/animals/amethyst-orblight/', label: 'Amethyst Orblight' },
  { href: '/world/animals/hearthcrest-caller/', label: 'Hearthcrest Caller' },
  { href: '/world/animals/', label: 'Animals of Vaelinya' },
];
---
<AnimalPage
  title="Mosskeep Frog"
  description="A colourful moss-backed frog of Vaelinya."
  lede="A colourful blue-green-gold frog with a living moss garden growing across its back."
  facts={facts}
  accessNote="Mosskeep Frogs are colourful blue-green-gold frogs with golden eyes and living moss gardens on their backs."
  links={links}
  image={{
    src: '/assets/images/vaelinya/animals/mosskeep-frog-v01-1024-q.png',
    src768: '/assets/images/vaelinya/animals/mosskeep-frog-v01-768-q.png',
    src512: '/assets/images/vaelinya/animals/mosskeep-frog-v01-512-q.png',
    alt: 'Mosskeep Frog, a colourful blue-green-gold frog with golden eyes and a living moss garden of tiny flowers, seed pods, and dew-orbs growing across its back.',
    width: 1024,
    height: 1024,
  }}
  caption="A Mosskeep Frog carrying a living garden of moss, flowers, seed pods, and dew-orbs."
  background={{
    large: '/assets/images/vaelinya/animals/mosskeep-frog-habitat-v01.png',
    small: '/assets/images/vaelinya/animals/mosskeep-frog-habitat-v01.png',
  }}
  artWidth="320px"
  artDesktopWidth="300px"
  artTabletWidth="280px"
  artMobileWidth="280px"
/>
