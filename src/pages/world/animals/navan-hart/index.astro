---
import AnimalPage from '../../../../components/AnimalPage.astro';

const facts = [
  {
    term: 'What it is',
    detail: 'A rare memory animal and witness animal. It is not a pet, monster, or ordinary deer; its appearance means something has been remembered truthfully.',
  },
  {
    term: 'Where it appears',
    detail: 'Old road bends, forest glades, quiet path stones, soft mist, remembered places, and ground where hidden truth has begun to return.',
  },
  {
    term: 'How to recognise it',
    detail: 'Look for a deep warm brown body, moon-white antlers, calm dark eyes, small route-marks along the neck, and a quiet old-road presence.',
  },
  {
    term: 'Sound and movement',
    detail: 'It is almost silent. Its hooves make a soft double step, even when it walks alone, as if memory is walking beside it.',
  },
  {
    term: 'What it means',
    detail: 'It appears only where memory has been carried truthfully rather than hidden, denied, or wasted. Its appearance means healing can begin.',
  },
];

const links = [
  { href: '/artefacts/symbols/navan/', label: 'NAVAN symbol' },
  { href: '/world/warm-remembering/', label: 'Warm Remembering' },
  { href: '/world/animals/', label: 'Animals of Vaelinya' },
];
---
<AnimalPage
  title="Navan Hart"
  description="A rare memory animal of Vaelinya."
  lede="A rare deerlike memory animal that appears where a place has remembered a truth clearly enough to begin healing."
  facts={facts}
  accessNote="The Navan Hart is a rare deerlike animal with moon-white antlers, calm dark eyes, route-marks along its neck, and a quiet double step."
  links={links}
  image={{
    src: '/assets/images/vaelinya/animals/navan-hart-v01-1024-q.png',
    src768: '/assets/images/vaelinya/animals/navan-hart-v01-768-q.png',
    src512: '/assets/images/vaelinya/animals/navan-hart-v01-512-q.png',
    alt: 'Navan Hart, a rare deerlike memory animal with a deep warm brown body, moon-white antlers, calm dark eyes, small route-marks along its neck, and a quiet old-road presence.',
    width: 1024,
    height: 1287,
  }}
  caption="A Navan Hart with moon-white antlers, route-marks, and a quiet old-road presence."
  background={{
    large: '/assets/images/vaelinya/animals/navan-hart-habitat-v01-1920.jpg',
    small: '/assets/images/vaelinya/animals/navan-hart-habitat-v01-1280.jpg',
  }}
  variant="tall"
  grid="minmax(0, 1.18fr) minmax(300px, 0.82fr)"
  artWidth="390px"
  artDesktopWidth="390px"
  artTabletWidth="360px"
  artMobileWidth="330px"
  artGlow="drop-shadow(0 0 18px rgba(225, 209, 168, 0.18)) drop-shadow(0 22px 34px rgba(22, 14, 39, 0.22))"
  bgAccent="radial-gradient(circle at 58% 16%, rgba(241, 239, 226, 0.22), transparent 34%)"
  bgOverlayLarge="linear-gradient(rgba(16, 17, 20, 0.12), rgba(16, 17, 20, 0.46))"
  bgOverlaySmall="linear-gradient(rgba(16, 17, 20, 0.14), rgba(16, 17, 20, 0.5))"
/>
