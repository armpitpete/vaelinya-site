---
import AnimalPage from '../../../../components/AnimalPage.astro';

const facts = [
  {
    term: 'What it is',
    detail: 'A river-and-sea fish of the Great River, with route memory, salt-light shimmer, and movement that belongs to Vaelinya’s own water logic.',
  },
  {
    term: 'Where it lives',
    detail: 'Great River channels, bridge pools, wet stone shallows, root-shadowed banks, salt-glimmer water, and places where the sea seems to arrive from two directions.',
  },
  {
    term: 'How to recognise it',
    detail: 'Look for blue-green-silver scales, pale gold gill marks, long flowing fins, river-glass shine, and body markings that suggest routes and tides.',
  },
  {
    term: 'Sound and movement',
    detail: 'It makes a low river-pulse that can be felt through wet stones, wooden boats, bridge posts, or riverbank roots. Groups turn as if remembering two currents at once.',
  },
  {
    term: 'What it does',
    detail: 'It carries sea minerals, river memory, small drifting life, and route signs between salt-influenced water and river water.',
  },
];

const links = [
  { href: '/world/animals/navan-hart/', label: 'Navan Hart' },
  { href: '/world/animals/mosskeep-frog/', label: 'Mosskeep Frog' },
  { href: '/world/animals/', label: 'Animals of Vaelinya' },
];
---
<AnimalPage
  title="Rimmer Fish"
  description="Great River fish that come from the sea both ways."
  lede="A blue-green-silver Great River fish that comes from the sea both ways and moves through the water in route-sensitive groups."
  facts={facts}
  accessNote="Rimmer Fish are blue-green-silver fish of the Great River. They come from the sea both ways and move in groups that show route and tide memory."
  links={links}
  image={{
    src: '/assets/images/vaelinya/animals/rimmer-fish-v01-1024-q.png',
    src768: '/assets/images/vaelinya/animals/rimmer-fish-v01-768-q.png',
    src512: '/assets/images/vaelinya/animals/rimmer-fish-v01-512-q.png',
    alt: 'Rimmer Fish, a blue-green-silver fish with pale gold gill marks, long flowing fins, river-glass scales, salt-light shimmer, and route-like markings along its body.',
    width: 1024,
    height: 617,
  }}
  caption="A Rimmer Fish with flowing fins, river-glass scales, and route-like markings along its body."
  background={{
    large: '/assets/images/vaelinya/animals/rimmer-fish-habitat-v01-1920.jpg',
    small: '/assets/images/vaelinya/animals/rimmer-fish-habitat-v01-1280.jpg',
  }}
  variant="wide"
  grid="minmax(0, 1.05fr) minmax(400px, 0.95fr)"
  artWidth="520px"
  artDesktopWidth="520px"
  artTabletWidth="520px"
  artMobileWidth="460px"
  artGlow="drop-shadow(0 0 22px rgba(101, 225, 236, 0.22)) drop-shadow(0 22px 34px rgba(22, 14, 39, 0.22))"
  bgAccent="radial-gradient(circle at 44% 22%, rgba(230, 255, 247, 0.24), transparent 34%)"
  bgOverlayLarge="linear-gradient(rgba(10, 43, 58, 0.12), rgba(10, 43, 58, 0.42))"
  bgOverlaySmall="linear-gradient(rgba(10, 43, 58, 0.14), rgba(10, 43, 58, 0.46))"
/>
