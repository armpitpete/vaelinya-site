---
import AnimalPage from '../../../../components/AnimalPage.astro';

const facts = [
  {
    term: 'What it is',
    detail: 'A small luminous insect with a dark centre, soft orb abdomen, translucent wings, and glowing antenna tips.',
  },
  {
    term: 'Where it lives',
    detail: 'Moonlit meadows, warm grassland paths, purple flower beds, dark moss, dew-orbs, and calm resting grounds used by elder fauna.',
  },
  {
    term: 'How to recognise it',
    detail: 'Look for violet-amethyst glow, a readable insect body, glassy veined wings, tiny curved legs, and antennae that pulse like small lanterns.',
  },
  {
    term: 'Sound and movement',
    detail: 'It makes a low glassy hum with a soft pulsing buzz. Groups drift in slow circles, then gather into loose spirals near warmth.',
  },
  {
    term: 'What it does',
    detail: 'It helps connect flower-light, warmth, feeding windows, dung nursery sites, and grassland renewal around Hearthcrest Callers.',
  },
];

const links = [
  { href: '/world/animals/hearthcrest-caller/', label: 'Hearthcrest Caller' },
  { href: '/world/animals/mosskeep-frog/', label: 'Mosskeep Frog' },
  { href: '/world/animals/', label: 'Animals of Vaelinya' },
];
---
<AnimalPage
  title="Amethyst Orblight"
  description="A violet glowing insect linked to Hearthcrest Callers."
  lede="A tiny violet-amethyst insect whose glow and hum gather around warmth, flowers, and elder-animal resting paths."
  facts={facts}
  accessNote="Amethyst Orblights are tiny violet glowing insects with dark centres, translucent wings, glowing antenna tips, and a soft glassy hum."
  links={links}
  image={{
    src: '/assets/images/vaelinya/animals/amethyst-orblight-v01-1024-q.png',
    src768: '/assets/images/vaelinya/animals/amethyst-orblight-v01-768-q.png',
    src512: '/assets/images/vaelinya/animals/amethyst-orblight-v01-512-q.png',
    alt: 'Amethyst Orblight, a small glowing violet-amethyst insect with a dark centre, soft orb abdomen, translucent veined wings, tiny curved legs, and glowing antenna tips.',
    width: 1024,
    height: 1024,
  }}
  caption="An Amethyst Orblight with glowing antenna tips, veined wings, and a soft orb abdomen."
  background={{
    large: '/assets/images/vaelinya/animals/amethyst-orblight-habitat-v01-1920.jpg',
    small: '/assets/images/vaelinya/animals/amethyst-orblight-habitat-v01-1280.jpg',
  }}
  artWidth="310px"
  artDesktopWidth="300px"
  artTabletWidth="280px"
  artMobileWidth="280px"
  artGlow="drop-shadow(0 0 18px rgba(184, 87, 255, 0.32)) drop-shadow(0 18px 28px rgba(22, 14, 39, 0.2))"
  bgAccent="radial-gradient(circle at 52% 22%, rgba(244, 221, 255, 0.22), transparent 32%)"
  bgOverlayLarge="linear-gradient(rgba(18, 8, 44, 0.2), rgba(18, 8, 44, 0.5))"
  bgOverlaySmall="linear-gradient(rgba(18, 8, 44, 0.22), rgba(18, 8, 44, 0.54))"
/>
