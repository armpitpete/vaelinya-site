---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { storybookChapters } from '../../data/storybookChapters';
---
<BaseLayout title="A Storybook of Vaelinya" description="Begin the guided Storybook journey through Vaelinya.">
  <link rel="stylesheet" href="/styles/storybook-start.css?v=2026-05-24-02" />
  <div class="storybook-start-page">
    <section class="page-section storybook-start-hero">
      <p class="eyebrow">Start</p>
      <h1>A Storybook of Vaelinya.</h1>
      <p class="lede">Explore Vaelinya through illustrated chapters, sounds, small choices, guide handovers, and gentle puzzles.</p>
      <p>The reader learns Vaelinya by moving through it. Chapter One opens the format, then Chapter Two moves to Nearside, where Lina lives.</p>
      <p><a class="button" href="/start/chapter-one/">Open Chapter One: The First Walk</a></p>
    </section>

    <section class="page-section">
      <p class="eyebrow">Eight chapters</p>
      <h2>Journey order</h2>
      <div class="storybook-chapter-grid" aria-label="Storybook chapter order">
        {storybookChapters.map((chapter) => (
          <a
            class={`storybook-chapter-card storybook-chapter-card--${chapter.number}`}
            href={chapter.status === 'active' ? chapter.route : '#'}
            aria-label={`Chapter ${chapter.number}: ${chapter.title}`}
          >
            <span class="storybook-chapter-card__image" aria-hidden="true">
              <span class="storybook-chapter-card__mark"></span>
            </span>
            <span class="storybook-chapter-card__copy">
              <span class="storybook-chapter-card__number">Chapter {chapter.number}</span>
              <strong>{chapter.title}</strong>
            </span>
          </a>
        ))}
      </div>
    </section>
  </div>
</BaseLayout>
