import BaseLayout from '../../../layouts/BaseLayout.astro';
---
<BaseLayout title="Symbols" description="Public symbols of Vaelinya.">
  <section class="page-section">
    <p class="eyebrow">Artefacts</p>
    <h1>Symbols</h1>
    <p class="lede">Symbols carry memory, identity, and recognition across the world of Vaelinya.</p>
    <p>A symbol may be worn, carved, drawn, printed, remembered, or recognised in a story. It gives a reader something small and visible to hold onto while the world grows larger.</p>
    <p>This public section will gather stable marks, recurring signs, and meaningful visual forms as canon is extracted safely.</p>
    <div class="link-list">
      <a href="/language/lexicon/">Words behind symbols</a>
      <a href="/artefacts/story-objects/">Story objects</a>
    </div>
  </section>
</BaseLayout>
