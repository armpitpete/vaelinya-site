import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout title="Artefacts" description="Maps, symbols, chant cards, story objects, and printables from Vaelinya.">
  <section class="page-section">
    <p class="eyebrow">Artefacts</p>
    <h1>Discover artefacts.</h1>
    <p class="lede">Artefacts are the visible pieces of Vaelinya: symbols, maps, chant cards, story objects, and printable things readers can use, follow, or keep close.</p>
    <p>They turn the world into small concrete forms: a mark to recognise, a route to follow, an object from a story, or a card for learning.</p>
    <div class="link-list">
      <a href="/artefacts/symbols/">Symbols</a>
      <a href="/artefacts/maps/">Maps</a>
      <a href="/artefacts/chant-cards/">Chant cards</a>
      <a href="/artefacts/story-objects/">Story objects</a>
      <a href="/artefacts/printables/">Printables</a>
    </div>
  </section>
</BaseLayout>
