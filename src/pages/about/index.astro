---
import BaseLayout from '../../layouts/BaseLayout.astro';

const description = 'About Vaelinya: a colourful, illustrated story world by Merrin W. Dream, with stories, world, language, and artefacts for readers to explore.';
const site = Astro.site ?? new URL('https://vaelinya.uk');
const pageUrl = new URL('/about/', site).toString();
const homepageUrl = new URL('/', site).toString();

const aboutJsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'AboutPage',
    name: 'About Vaelinya',
    description,
    url: pageUrl,
    inLanguage: 'en',
    isPartOf: {
      '@type': 'WebSite',
      name: 'Vaelinya',
      url: homepageUrl,
    },
    about: {
      '@type': 'CreativeWorkSeries',
      name: 'Vaelinya',
      description: 'A colourful, illustrated, learnable story world where readers can begin with stories, then explore world, language, and artefacts.',
      url: homepageUrl,
      inLanguage: 'en',
      creator: {
        '@type': 'Person',
        name: 'Merrin W. Dream',
      },
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Person',
    name: 'Merrin W. Dream',
    description: 'Merrin W. Dream is a writer, artist, musician, worldbuilder, and synth maker based in York.',
    url: pageUrl,
  },
];
---
<BaseLayout title="About Vaelinya" description={description} jsonLd={aboutJsonLd}>
  <section class="page-section">
    <p class="eyebrow">About</p>
    <h1>About Vaelinya</h1>
    <p class="lede">Vaelinya is a colourful, illustrated, learnable story world created by Merrin W. Dream.</p>
    <p>It is built as a public adventure doorway. Readers can begin with stories, then follow the world, language, and artefacts as they open.</p>
    <p>Vaelinya is not a game, a wiki, or a random fantasy glossary. It is a story world first. The reference pages exist to make the stories richer, clearer, and easier to enter.</p>

    <article class="panel" aria-labelledby="where-to-start-title">
      <p class="eyebrow">Where to start</p>
      <h2 id="where-to-start-title">Begin with one clear path</h2>
      <p>The easiest first step is Lina’s story path. Lina is the first bridge child: a listener, a witness, and a quiet connector. Her stories introduce Vaelinya through feeling, place, courage, and small acts of attention.</p>
      <div class="link-list">
        <a href="/read/lina/">Start with Lina’s eight stories</a>
        <a href="/read/lina/01-the-bridge-that-sang-back/">Read Story 01: The Bridge That Sang Back</a>
      </div>
    </article>

    <article class="panel" aria-labelledby="sections-title">
      <p class="eyebrow">How the site works</p>
      <h2 id="sections-title">Four public doors</h2>
      <ul>
        <li><strong>Read</strong> is the story doorway. Start here when you want the world to arrive through characters and events.</li>
        <li><strong>World</strong> explains places, people, customs, animals, and the wider shape of Vaelinya.</li>
        <li><strong>Language</strong> teaches words, sounds, meanings, and word-families in small clear steps.</li>
        <li><strong>Artefacts</strong> holds symbols, maps, objects, chant cards, and printable things from inside the world.</li>
      </ul>
      <div class="link-list">
        <a href="/read/">Read</a>
        <a href="/world/">World</a>
        <a href="/language/">Language</a>
        <a href="/artefacts/">Artefacts</a>
      </div>
    </article>

    <article class="panel" aria-labelledby="merrin-title">
      <p class="eyebrow">Creator</p>
      <h2 id="merrin-title">Merrin W. Dream</h2>
      <p>Merrin W. Dream is a writer, artist, musician, worldbuilder, and synth maker based in York.</p>
      <p>Merrin writes fiction, builds story worlds, makes songs, designs instruments, and teaches neurodivergent-friendly storytelling. The work returns to hidden lives, difficult perception, longing, care, and the way some people are made almost ghostlike by a world that does not know how to see them clearly.</p>
    </article>

    <article class="panel" aria-labelledby="public-canon-title">
      <p class="eyebrow">Public site</p>
      <h2 id="public-canon-title">What belongs here</h2>
      <p>This site holds the public-facing version of Vaelinya: readable stories, useful orientation pages, clear language material, and artefacts that help the world feel real.</p>
      <p>The deeper working canon remains in the private project files. The public site gives readers enough to begin without exposing every planning document behind the world.</p>
    </article>
  </section>
</BaseLayout>
