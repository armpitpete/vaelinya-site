---
import BaseLayout from '../../layouts/BaseLayout.astro';

const description = 'About Vaelinya: a colourful story world by Merrin W. Dream, where readers can begin with stories and then explore places, language, symbols, maps, and artefacts.';
const site = Astro.site ?? new URL('https://vaelinya.uk');
const pageUrl = new URL('/about/', site).toString();
const homepageUrl = new URL('/', site).toString();

const aboutJsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'AboutPage',
    name: 'About Vaelinya',
    description,
    url: pageUrl,
    inLanguage: 'en',
    isPartOf: {
      '@type': 'WebSite',
      name: 'Vaelinya',
      url: homepageUrl,
    },
    about: {
      '@type': 'CreativeWorkSeries',
      name: 'Vaelinya',
      description: 'A colourful story world where readers can begin with stories and then explore places, language, symbols, maps, and artefacts.',
      url: homepageUrl,
      inLanguage: 'en',
      creator: {
        '@type': 'Person',
        name: 'Merrin W. Dream',
      },
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Person',
    name: 'Merrin W. Dream',
    description: 'Merrin W. Dream is a writer, artist, musician, worldbuilder, and synth maker based in York.',
    url: pageUrl,
  },
];
---
<BaseLayout title="About Vaelinya" description={description} jsonLd={aboutJsonLd}>
  <section class="page-section">
    <p class="eyebrow">About</p>
    <h1>About Vaelinya</h1>
    <p class="lede">Vaelinya is a colourful story world created by Merrin W. Dream.</p>
    <p>It begins with stories. From there, you can follow the places, words, symbols, maps, and objects that belong to the world.</p>
    <p>You can start reading straight away. The extra pages are here when you want to understand something more clearly.</p>

    <article class="panel" aria-labelledby="where-to-start-title">
      <p class="eyebrow">Start here</p>
      <h2 id="where-to-start-title">Read Lina first</h2>
      <p>Lina’s stories are the clearest first path into Vaelinya. She listens carefully, notices what others miss, and helps the world open gently around the reader.</p>
      <p>Read one story first. Then follow any place, word, symbol, or object that catches your attention.</p>
      <div class="link-list">
        <a href="/read/lina/">Start with Lina’s eight stories</a>
        <a href="/read/lina/01-the-bridge-that-sang-back/">Read Story 01: The Bridge That Sang Back</a>
      </div>
    </article>

    <article class="panel" aria-labelledby="sections-title">
      <p class="eyebrow">How to use the site</p>
      <h2 id="sections-title">Four ways in</h2>
      <ul>
        <li><strong>Read</strong> gives you the stories.</li>
        <li><strong>World</strong> explains the places, people, customs, animals, and shared life of Vaelinya.</li>
        <li><strong>Language</strong> gathers words, meanings, pronunciations, and word-families.</li>
        <li><strong>Artefacts</strong> collects symbols, maps, objects, chant cards, and printable things from the world.</li>
      </ul>
      <div class="link-list">
        <a href="/read/">Read</a>
        <a href="/world/">World</a>
        <a href="/language/">Language</a>
        <a href="/artefacts/">Artefacts</a>
      </div>
    </article>

    <article class="panel" aria-labelledby="merrin-title">
      <p class="eyebrow">Creator</p>
      <h2 id="merrin-title">Merrin W. Dream</h2>
      <p>Merrin W. Dream is a writer, artist, musician, worldbuilder, and synth maker based in York.</p>
      <p>Merrin writes fiction, builds story worlds, makes songs, designs instruments, and teaches neurodivergent-friendly storytelling. The work often returns to hidden lives, difficult perception, longing, care, and the need to be seen clearly.</p>
    </article>

    <article class="panel" aria-labelledby="public-site-title">
      <p class="eyebrow">Public site</p>
      <h2 id="public-site-title">What this site gives you</h2>
      <p>This is the public doorway into Vaelinya. It gives readers enough to enter the world, follow the stories, and understand the most useful parts of the setting.</p>
      <p>There is more behind the scenes, but this site keeps the first experience clear: story first, then world, language, and artefacts when they are useful.</p>
    </article>
  </section>
</BaseLayout>
