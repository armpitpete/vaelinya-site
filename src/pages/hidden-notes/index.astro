---
import BaseLayout from '../../layouts/BaseLayout.astro';

const description = 'A quiet star-map of things the stories do not say aloud.';
---
<BaseLayout title="Hidden Notes" description={description} noindex={true}>
  <section class="hidden-notes-page" aria-labelledby="hidden-notes-title">
    <div class="hidden-notes-hero">
      <div class="hidden-notes-copy">
        <p class="eyebrow">Hidden Notes</p>
        <h1 id="hidden-notes-title">The stars around Vaelinya</h1>
        <p class="lede">A quiet star-map of things the stories do not say aloud.</p>
      </div>

      <div class="vaelinya-star-map" aria-label="A magical star-map around Vaelinya">
        <div class="map-haze map-haze-one" aria-hidden="true"></div>
        <div class="map-haze map-haze-two" aria-hidden="true"></div>
        <div class="orbit orbit-one" aria-hidden="true"></div>
        <div class="orbit orbit-two" aria-hidden="true"></div>
        <div class="orbit orbit-three" aria-hidden="true"></div>
        <div class="vaelinya-world" aria-hidden="true">Vaelinya</div>

        <div class="whisper-star bridge-star" aria-hidden="true">
          <span class="star-core"></span>
          <div class="whisper-popup">
            <p class="whisper-kicker">The Bridge That Sang Back</p>
            <p>The bridge was not built from stone. It appeared because Lina joined the canyon’s hidden song.</p>
          </div>
        </div>

        <span class="quiet-star s1" aria-hidden="true"></span>
        <span class="quiet-star s2" aria-hidden="true"></span>
        <span class="quiet-star s3" aria-hidden="true"></span>
        <span class="quiet-star s4" aria-hidden="true"></span>
        <span class="quiet-star s5" aria-hidden="true"></span>
        <span class="quiet-star s6" aria-hidden="true"></span>
        <span class="quiet-star s7" aria-hidden="true"></span>
      </div>
    </div>

    <article class="panel first-hidden-note" aria-labelledby="first-hidden-note-title">
      <p class="eyebrow">First hidden note</p>
      <h2 id="first-hidden-note-title">The Old Listening-Place</h2>
      <p>The bridge is an old listening-place. It appears because Lina joins its hidden song, not because she solves a puzzle or casts a spell.</p>
    </article>
  </section>
</BaseLayout>

<style>
  .hidden-notes-page {
    width: min(1120px, calc(100vw - 2rem));
    margin: 0 auto;
  }

  .hidden-notes-hero {
    position: relative;
    overflow: hidden;
    border: 1px solid rgba(236, 215, 167, 0.28);
    border-radius: 2rem;
    padding: clamp(1.4rem, 4vw, 3rem);
    background:
      radial-gradient(circle at 18% 12%, rgba(143, 210, 190, 0.13), transparent 18rem),
      radial-gradient(circle at 82% 24%, rgba(255, 226, 154, 0.09), transparent 20rem),
      linear-gradient(135deg, #150d28, #060611 72%);
    color: #fff7df;
    box-shadow: 0 1rem 4rem rgba(5, 5, 18, 0.35);
  }

  .hidden-notes-copy {
    max-width: 42rem;
  }

  .hidden-notes-hero h1,
  .first-hidden-note h2 {
    font-family: Georgia, 'Times New Roman', serif;
  }

  .hidden-notes-hero h1 {
    color: #fff3cf;
  }

  .hidden-notes-hero p {
    color: rgba(255, 247, 223, 0.9);
  }

  .vaelinya-star-map {
    position: relative;
    min-height: clamp(22rem, 52vw, 34rem);
    margin-top: 2rem;
    border-radius: 1.5rem;
    border: 1px solid rgba(255, 247, 223, 0.16);
    background:
      radial-gradient(circle at 18% 26%, rgba(255, 255, 255, 0.88) 0 1px, transparent 2px),
      radial-gradient(circle at 76% 18%, rgba(255, 248, 225, 0.72) 0 1px, transparent 2px),
      radial-gradient(circle at 88% 72%, rgba(255, 255, 255, 0.74) 0 1px, transparent 2px),
      radial-gradient(circle at 34% 78%, rgba(255, 248, 225, 0.62) 0 1px, transparent 2px),
      radial-gradient(circle at 56% 34%, rgba(255, 255, 255, 0.52) 0 1px, transparent 2px),
      radial-gradient(circle at 50% 50%, rgba(255, 223, 142, 0.15), transparent 38%),
      linear-gradient(180deg, rgba(14, 12, 38, 0.94), rgba(4, 4, 14, 0.98));
    overflow: hidden;
    isolation: isolate;
  }

  .map-haze {
    position: absolute;
    border-radius: 999px;
    filter: blur(10px);
    opacity: 0.5;
    pointer-events: none;
  }

  .map-haze-one {
    inset: 18% 48% 20% 8%;
    background: radial-gradient(circle, rgba(108, 184, 214, 0.2), transparent 68%);
  }

  .map-haze-two {
    inset: 10% 8% 34% 52%;
    background: radial-gradient(circle, rgba(255, 218, 126, 0.16), transparent 66%);
  }

  .orbit {
    position: absolute;
    left: 50%;
    top: 50%;
    border: 1px solid rgba(255, 239, 197, 0.12);
    border-radius: 50%;
    transform: translate(-50%, -50%) rotate(-12deg);
  }

  .orbit-one { width: 38%; aspect-ratio: 1; }
  .orbit-two { width: 60%; aspect-ratio: 1; }
  .orbit-three { width: 82%; aspect-ratio: 1; }

  .vaelinya-world {
    position: absolute;
    left: 50%;
    top: 50%;
    width: clamp(8rem, 22vw, 13rem);
    aspect-ratio: 1;
    display: grid;
    place-items: center;
    border-radius: 50%;
    transform: translate(-50%, -50%);
    background:
      radial-gradient(circle at 35% 28%, rgba(255, 255, 255, 0.9), transparent 0.55rem),
      radial-gradient(circle at 50% 52%, #8fd2be 0, #355774 58%, #1d1d3f 100%);
    color: #fff7df;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    box-shadow:
      0 0 2rem rgba(142, 213, 214, 0.32),
      inset 0 0 1.4rem rgba(255, 247, 223, 0.18);
    z-index: 2;
  }

  .quiet-star {
    position: absolute;
    width: 0.3rem;
    height: 0.3rem;
    border-radius: 50%;
    background: rgba(255, 243, 207, 0.72);
    box-shadow: 0 0 0.7rem rgba(255, 228, 157, 0.56);
    z-index: 2;
  }

  .s1 { left: 23%; top: 40%; }
  .s2 { left: 31%; top: 64%; }
  .s3 { left: 62%; top: 28%; }
  .s4 { left: 71%; top: 62%; }
  .s5 { left: 80%; top: 42%; }
  .s6 { left: 42%; top: 22%; }
  .s7 { left: 52%; top: 76%; }

  .whisper-star {
    display: none;
  }

  @media (hover: hover) and (pointer: fine) {
    .whisper-star {
      position: absolute;
      display: grid;
      place-items: center;
      width: 1.75rem;
      height: 1.75rem;
      z-index: 4;
    }

    .bridge-star {
      left: 25%;
      top: 46%;
    }

    .star-core {
      width: 0.48rem;
      height: 0.48rem;
      border-radius: 50%;
      background: #fff5c7;
      box-shadow: 0 0 0.35rem #fff9d9, 0 0 1.1rem rgba(255, 214, 112, 0.66);
      transition: transform 0.22s ease, box-shadow 0.22s ease;
    }

    .whisper-star:hover .star-core {
      transform: scale(1.35);
      box-shadow: 0 0 0.45rem #ffffec, 0 0 1.75rem rgba(255, 218, 126, 0.9);
    }

    .whisper-popup {
      position: absolute;
      left: 50%;
      bottom: calc(100% + 0.7rem);
      width: min(18rem, 42vw);
      padding: 0.82rem 0.95rem;
      border: 1px solid rgba(255, 231, 167, 0.34);
      border-radius: 1rem;
      background: rgba(35, 23, 50, 0.96);
      color: #fff7df;
      opacity: 0;
      pointer-events: none;
      transform: translate(-50%, 0.35rem);
      transition: opacity 0.35s ease, transform 0.35s ease;
      transition-delay: 0s;
      box-shadow: 0 1rem 2rem rgba(4, 4, 14, 0.36);
    }

    .whisper-star:hover .whisper-popup {
      opacity: 1;
      pointer-events: auto;
      transform: translate(-50%, 0);
      transition-delay: 1.4s;
    }

    .whisper-popup p {
      margin: 0;
      color: rgba(255, 247, 223, 0.92);
      font-size: 0.92rem;
      line-height: 1.45;
    }

    .whisper-popup .whisper-kicker {
      margin-bottom: 0.35rem;
      color: rgba(255, 226, 154, 0.94);
      font-size: 0.7rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
    }
  }

  .first-hidden-note {
    margin-top: 1.4rem;
  }
</style>
