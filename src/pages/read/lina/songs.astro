---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const description = 'Songs from Lina’s stories in Vaelinya.';
---

<BaseLayout title="Lina’s Songs" description={description}>
  <section class="page-section">
    <p class="eyebrow">Lina’s Songs</p>
    <h1>Lina’s songs</h1>

    <p class="lede">
      Each Lina story has its own song.
    </p>

    <p>
      The songs follow how Lina listens, notices, waits, answers, and finds her way through Vaelinya.
    </p>

    <article class="panel">
      <p class="eyebrow">Lina theme song</p>
      <h2>Just Lina</h2>

      <p>
        A song about who Lina is: quiet, observant, careful, and strong in her own way.
      </p>

      <figure class="audio-panel">
        <figcaption>Listen to Just Lina</figcaption>
        <audio controls preload="metadata" src="/audio/lina/Just%20Lina.mp3">
          Your browser does not support the audio player. You can open the song file directly at
          <a href="/audio/lina/Just%20Lina.mp3">Just Lina</a>.
        </audio>
      </figure>
    </article>

    <article class="panel">
      <p class="eyebrow">Song 01</p>
      <h2>Lina Hears the Hidden Song</h2>

      <p>
        <strong>From:</strong> the bridge-song story.
      </p>

      <p>
        A song about too much noise, one hidden sound, and Lina finding the rhythm that lets the world answer back.
      </p>

      <figure class="audio-panel">
        <figcaption>Listen to Lina Hears the Hidden Song</figcaption>
        <audio controls preload="metadata" src="/audio/lina/Lina%20Hears%20the%20Hidden%20Song.mp3">
          Your browser does not support the audio player. You can open the song file directly at
          <a href="/audio/lina/Lina%20Hears%20the%20Hidden%20Song.mp3">Lina Hears the Hidden Song</a>.
        </audio>
      </figure>

      <div class="link-list">
        <a href="/read/lina/01-the-bridge-that-sang-back/">Read the story</a>
        <a href="/read/lina/">Return to Lina’s stories</a>
      </div>
    </article>

    <article class="panel">
      <h2>More Lina songs are coming</h2>
    </article>
  </section>
</BaseLayout>

<style>
  .audio-panel {
    margin: 1.4rem 0;
    padding: 1rem;
    border: 1px solid rgba(75, 43, 92, 0.18);
    border-radius: 1rem;
    background: rgba(255, 255, 255, 0.48);
  }

  .audio-panel figcaption {
    margin-bottom: 0.65rem;
    font-weight: 800;
  }

  .audio-panel audio {
    display: block;
    width: 100%;
  }
</style>
