---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const description = 'Songs from Lina’s stories in Vaelinya.';
---

<BaseLayout title="Lina’s Songs" description={description}>
  <section class="page-section lina-songs-page">
    <header class="lina-songs-hero">
      <div class="lina-songs-hero-copy">
        <p class="eyebrow">Lina’s Songs</p>
        <h1>Lina’s songs</h1>

        <p class="lede">
          Each Lina story has its own song.
        </p>

        <p>
          The songs follow how Lina listens, notices, waits, answers, and finds her way through Vaelinya.
        </p>

        <p class="lina-songs-hero-note">
          Songs for Lina’s stories, quiet ways, and hidden sounds.
        </p>
      </div>

      <figure class="lina-songs-hero-art">
        <img
          src="/images/characters/lina/lina_side_shot.webp"
          alt="Side profile of Lina with dark braided hair and beads."
          width="246"
          height="342"
          loading="eager"
          decoding="async"
        />
      </figure>
    </header>

    <article class="panel">
      <p class="eyebrow">Lina theme song</p>
      <h2>Just Lina</h2>

      <p>
        A song about who Lina is: quiet, observant, careful, and strong in her own way.
      </p>

      <figure class="audio-panel">
        <figcaption>Listen to Just Lina</figcaption>
        <audio controls preload="metadata" src="/audio/lina/Just%20Lina.mp3">
          Your browser does not support the audio player. You can open the song file directly at
          <a href="/audio/lina/Just%20Lina.mp3">Just Lina</a>.
        </audio>
      </figure>
    </article>

    <article class="panel">
      <p class="eyebrow">Song 01</p>
      <h2>Lina Hears the Hidden Song</h2>

      <p>
        <strong>From:</strong> the bridge-song story.
      </p>

      <p>
        A song about too much noise, one hidden sound, and Lina finding the rhythm that lets the world answer back.
      </p>

      <figure class="audio-panel">
        <figcaption>Listen to Lina Hears the Hidden Song</figcaption>
        <audio controls preload="metadata" src="/audio/lina/Lina%20Hears%20the%20Hidden%20Song.mp3">
          Your browser does not support the audio player. You can open the song file directly at
          <a href="/audio/lina/Lina%20Hears%20the%20Hidden%20Song.mp3">Lina Hears the Hidden Song</a>.
        </audio>
      </figure>

      <div class="link-list">
        <a href="/read/lina/01-the-bridge-that-sang-back/">Read the story</a>
        <a href="/read/lina/">Return to Lina’s stories</a>
      </div>
    </article>

    <article class="panel">
      <h2>More Lina songs are coming</h2>
    </article>
  </section>
</BaseLayout>

<style>
  .lina-songs-page {
    position: relative;
    overflow: hidden;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.78), rgba(255, 255, 255, 0.9)),
      url('/images/read/lina/lina-songs-scene.webp') center center / cover no-repeat;
  }

  .lina-songs-hero {
    display: grid;
    grid-template-columns: minmax(0, 1.25fr) minmax(220px, 0.75fr);
    gap: 2rem;
    align-items: center;
    margin-bottom: 2rem;
    padding: 1.25rem 0 0.5rem;
  }

  .lina-songs-hero-copy {
    max-width: 42rem;
  }

  .lina-songs-hero-note {
    margin-top: 1rem;
    font-weight: 800;
    color: #4b2b5c;
  }

  .lina-songs-hero-art {
    display: flex;
    justify-content: center;
    align-items: end;
    margin: 0;
  }

  .lina-songs-hero-art img {
    display: block;
    width: min(100%, 18rem);
    height: auto;
    object-fit: contain;
    border-radius: 1.5rem;
    filter: drop-shadow(0 1rem 1.8rem rgba(34, 18, 50, 0.24));
  }

  .audio-panel {
    margin: 1.4rem 0;
    padding: 1rem;
    border: 1px solid rgba(75, 43, 92, 0.18);
    border-radius: 1rem;
    background: rgba(255, 255, 255, 0.48);
  }

  .audio-panel figcaption {
    margin-bottom: 0.65rem;
    font-weight: 800;
  }

  .audio-panel audio {
    display: block;
    width: 100%;
  }

  @media (max-width: 860px) {
    .lina-songs-hero {
      grid-template-columns: 1fr;
      gap: 1.25rem;
    }

    .lina-songs-hero-art {
      order: -1;
      justify-content: flex-start;
    }

    .lina-songs-hero-art img {
      width: min(100%, 13rem);
    }
  }
</style>
