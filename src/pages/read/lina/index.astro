---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';

const activeStories = (await getCollection('stories', ({ data }) => data.arc === 'Lina'))
  .sort((a, b) => a.data.story_number - b.data.story_number);

const storyByNumber = new Map(activeStories.map((story) => [story.data.story_number, story]));

const linaStoryPlan = [
  { number: 1, title: 'The Bridge That Sang Back' },
  { number: 2, title: 'The Cloud That Cries' },
  { number: 3, title: 'The Maze That Remembers' },
  { number: 4, title: 'The Mirror Pool' },
  { number: 5, title: 'The Sleeping Tree' },
  { number: 6, title: 'The Song That Found Its Voice' },
  { number: 7, title: 'The Star That Forgot to Shine' },
  { number: 8, title: 'The Whispering Cave' },
];

const linaStorySymbols = new Map([
  [1, { src: '/images/stories/lina/symbols/lina-symbol-01-bridge-light.svg', alt: 'A small glowing bridge symbol for The Bridge That Sang Back.' }],
  [2, { src: '/images/stories/lina/symbols/lina-symbol-02-rain-memory.svg', alt: 'A small crying cloud symbol for The Cloud That Cries.' }],
  [3, { src: '/images/stories/lina/symbols/lina-symbol-03-memory-leaf.svg', alt: 'A leaf with a maze-line symbol for The Maze That Remembers.' }],
  [4, { src: '/images/stories/lina/symbols/lina-symbol-04-mirror-stone.svg', alt: 'A mirror-stone with one glowing footstep for The Mirror Pool.' }],
  [5, { src: '/images/stories/lina/symbols/lina-symbol-05-sleeping-bud.svg', alt: 'A closed glowing bud symbol for The Sleeping Tree.' }],
  [6, { src: '/images/stories/lina/symbols/lina-symbol-06-path-reed.svg', alt: 'A glowing path-reed symbol for The Song That Found Its Voice.' }],
  [7, { src: '/images/stories/lina/symbols/lina-symbol-07-sky-seed.svg', alt: 'A small sky-seed symbol for The Star That Forgot to Shine.' }],
  [8, { src: '/images/stories/lina/symbols/lina-symbol-08-listening-stone.svg', alt: 'A listening-stone with eight tiny lights for The Whispering Cave.' }],
]);

const description = 'Lina’s first eight stories in Vaelinya.';
const site = Astro.site ?? new URL('https://vaelinya.uk');
const pageUrl = new URL('/read/lina/', site).toString();

const linaItemListJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Lina’s eight stories',
  description,
  url: pageUrl,
  numberOfItems: activeStories.length,
  itemListOrder: 'https://schema.org/ItemListOrderAscending',
  itemListElement: activeStories.map((story) => ({
    '@type': 'ListItem',
    position: story.data.story_number,
    url: new URL(story.data.public_url, site).toString(),
    name: story.data.title,
    description: story.data.description,
  })),
};
---
<BaseLayout title="Lina" description={description} jsonLd={linaItemListJsonLd}>
  <section class="page-section">
    <p class="eyebrow">Lina of Vaelinya</p>
    <h1>Lina’s eight stories</h1>
    <p class="lede">Lina is the first bridge child: a listener, a witness, and a quiet connector.</p>
    <p>These stories are the clearest first reading path into Vaelinya. They can be read in order as one gentle early arc of remembrance, courage, attention, and return.</p>

    <article class="panel">
      <p class="eyebrow">Related threads</p>
      <h2>What Lina helps you notice</h2>
      <p>Lina’s stories connect to the wider world through crossings, careful listening, remembered places, small acts of courage, and objects that carry meaning.</p>
      <div class="link-list">
        <a href="/world/the-rim/">World thread: The Rim</a>
        <a href="/language/lexicon/">Language thread: key words</a>
        <a href="/artefacts/symbols/">Artefact thread: symbols</a>
        <a href="/artefacts/maps/">Map thread: reader orientation</a>
      </div>
    </article>

    <div class="link-list">
      <a href="/read/lina/01-the-bridge-that-sang-back/">Begin with Story 01: The Bridge That Sang Back</a>
      <a href="/world/the-rim/">See the Rim</a>
    </div>

    <ol class="story-grid story-list lina-card-grid" aria-label="Lina stories in reading order">
      {linaStoryPlan.map((plannedStory) => {
        const story = storyByNumber.get(plannedStory.number);
        const fallbackSymbol = linaStorySymbols.get(plannedStory.number);
        const symbolSrc = fallbackSymbol?.src;
        const symbolAlt = fallbackSymbol?.alt ?? '';

        if (story) {
          return (
            <li>
              <a class={`story-card lina-story-card lina-story-card-${story.data.story_number}`} href={story.data.public_url} aria-label={`Read Story ${story.data.story_number}: ${story.data.title}`}>
                <span>Story {story.data.story_number}</span>
                <strong>{story.data.title}</strong>
                <p>{story.data.description}</p>
                <span class="story-card-action" aria-hidden="true">Read this story</span>
              </a>
            </li>
          );
        }

        return (
          <li>
            <article class="story-card story-card-pending" aria-label={`${plannedStory.title} is coming after repair`}>
              {symbolSrc && <img class="story-card-symbol" src={symbolSrc} alt={symbolAlt} loading="lazy" />}
              <span>Story {plannedStory.number}</span>
              <strong>{plannedStory.title}</strong>
              <p>Coming after repair.</p>
            </article>
          </li>
        );
      })}
    </ol>
  </section>
</BaseLayout>

<style>
  .lina-card-grid {
    align-items: stretch;
    grid-auto-rows: 1fr;
  }

  .lina-card-grid li {
    display: flex;
  }

  .lina-story-card {
    width: 100%;
    height: 100%;
    min-height: 17rem;
    position: relative;
    overflow: hidden;
    isolation: isolate;
    color: #fff8e8;
    background-color: #1d122e;
    background-size: cover;
    background-position: center;
    border: 1px solid rgba(255, 248, 232, 0.38);
    text-shadow: 0 0.12rem 0.5rem rgba(0, 0, 0, 0.78);
  }

  .lina-story-card > * {
    position: relative;
    z-index: 2;
  }

  .lina-story-card::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 0;
    background-image: inherit;
    background-size: inherit;
    background-position: inherit;
    filter: brightness(1.18) saturate(1.08);
    transform: scale(1.02);
  }

  .lina-story-card::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 1;
    background:
      linear-gradient(180deg, rgba(10, 7, 18, 0.08), rgba(10, 7, 18, 0.34) 42%, rgba(10, 7, 18, 0.82)),
      linear-gradient(90deg, rgba(10, 7, 18, 0.46), rgba(10, 7, 18, 0.08) 62%);
  }

  .lina-story-card-1 { background-image: url('/images/read/lina/lina-01-the-bridge-that-sang-back.webp'); background-position: center 42%; }
  .lina-story-card-2 { background-image: url('/images/read/lina/lina-02-the-cloud-that-cries.webp'); background-position: center 38%; }
  .lina-story-card-3 { background-image: url('/images/read/lina/lina-03-the-maze-that-remembers.webp'); background-position: center 44%; }
  .lina-story-card-4 { background-image: url('/images/read/lina/lina-04-the-mirror-pool.webp'); background-position: center 46%; }
  .lina-story-card-5 { background-image: url('/images/read/lina/lina-05-the-sleeping-tree.webp'); background-position: center 42%; }
  .lina-story-card-6 { background-image: url('/images/read/lina/lina-06-the-song-that-found-its-voice.webp'); background-position: center 42%; }
  .lina-story-card-7 { background-image: url('/images/read/lina/lina-07-the-star-that-forgot-to-shine.webp'); background-position: center 36%; }
  .lina-story-card-8 { background-image: url('/images/read/lina/lina-08-the-whispering-cave.webp'); background-position: center 50%; }

  .lina-story-card strong,
  .lina-story-card p {
    max-width: 16rem;
  }

  .lina-story-card p {
    color: rgba(255, 248, 232, 0.96);
  }

  .lina-story-card .story-card-action {
    margin-top: auto;
  }

  @media (max-width: 860px) {
    .lina-story-card { min-height: 14.5rem; }
  }
</style>
