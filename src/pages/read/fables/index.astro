---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const description = 'Small Vaelinyan fables that teach through creatures, places, objects, and choices.';
const site = Astro.site ?? new URL('https://vaelinya.uk');
const pageUrl = new URL('/read/fables/', site).toString();

const fables = [
  {
    title: 'The Line of White Pebbles',
    label: 'Boundary Fable',
    href: '/read/fables/the-line-of-white-pebbles/',
    image: '/images/read/fables/the-line-of-white-pebbles/hero.webp',
    imageAlt: 'A Thirst Beetle and a Slippy Snail face each other across a line of white pebbles.',
    description: 'A Thirst Beetle and a Slippy Snail learn that love must not harm what keeps another creature alive.',
    readingFeel: 'Gentle / Tender',
    bestFor: 'readers thinking about love, distance, and care',
    moralShape: 'Love is not proved by crossing a boundary. Sometimes love is proved by keeping one.',
  },
  {
    title: 'The Roof That Waited for Rain',
    label: 'Dwelling Fable',
    href: '/read/fables/the-roof-that-waited-for-rain/',
    image: '/images/read/fables/the-roof-that-waited-for-rain/hero.png',
    imageAlt: 'A young Vaelinyan named Aven stands outside a small blue-doored house, looking up at a dark patch in the living moss roof.',
    description: 'Aven has a living moss roof that only seems urgent when the rain begins.',
    readingFeel: 'Quiet / Gentle',
    bestFor: 'readers thinking about patience, shelter, and belonging',
    moralShape: 'A home is not a thing you possess. A home is care repeated over time.',
  },
];

const fablesJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Vaelinyan Fables',
  description,
  url: pageUrl,
  numberOfItems: fables.length,
  itemListOrder: 'https://schema.org/ItemListOrderAscending',
  itemListElement: fables.map((fable, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    url: new URL(fable.href, site).toString(),
    name: fable.title,
    description: fable.description,
  })),
};
---
<BaseLayout title="Vaelinyan Fables" description={description} jsonLd={fablesJsonLd}>
  <section class="page-section">
    <p class="eyebrow">Read</p>
    <h1>Vaelinyan fables</h1>
    <p class="lede">Small stories from Vaelinya that teach through creatures, places, objects, and choices.</p>
    <p>Each fable can be read on its own. Some fables also open small paths into the World, Language, and Artefacts sections later.</p>

    <article class="panel fable-system-panel">
      <p class="eyebrow">Vaelinyan Moral Fables</p>
      <h2>Teaching stories, not instructions</h2>
      <p>Vaelinyan Moral Fables are teaching stories.</p>
      <p>They do not tell the reader what to obey. They show the reader what to notice.</p>
      <p>A Vaelinyan fable may explain a creature, a ritual, a boundary, a transformation, a place, a return, or a leaving.</p>
      <p>The lesson is not usually spoken at the end. It is carried by the image the story leaves behind.</p>
    </article>

    <ol class="story-grid story-list fable-card-grid" aria-label="Vaelinyan fables">
      {fables.map((fable) => (
        <li>
          <a class="story-card fable-story-card" href={fable.href} aria-label={`Read ${fable.title}`}>
            <img class="fable-card-image" src={fable.image} alt={fable.imageAlt} loading="lazy" decoding="async" />
            <span>{fable.label}</span>
            <strong>{fable.title}</strong>
            <p>{fable.description}</p>
            <dl class="fable-card-meta">
              <div>
                <dt>Reading feel</dt>
                <dd>{fable.readingFeel}</dd>
              </div>
              <div>
                <dt>Best for</dt>
                <dd>{fable.bestFor}</dd>
              </div>
              <div>
                <dt>Moral shape</dt>
                <dd>{fable.moralShape}</dd>
              </div>
            </dl>
            <span class="story-card-action" aria-hidden="true">Read this fable</span>
          </a>
        </li>
      ))}
    </ol>

    <article class="panel">
      <p class="eyebrow">How to read them</p>
      <h2>Read first. Explore after.</h2>
      <p>Fables are story-first. Creature facts, symbols, artefacts, and language notes should support the story after the reader has met it.</p>
      <div class="link-list">
        <a href="/read/">Back to Read</a>
        <a href="/world/">Explore the World</a>
        <a href="/artefacts/">Find Artefacts</a>
      </div>
    </article>
  </section>
</BaseLayout>

<style>
  .fable-system-panel {
    margin-block: 2rem;
  }

  .fable-card-grid {
    grid-template-columns: repeat(auto-fit, minmax(16rem, 1fr));
    align-items: stretch;
  }

  .fable-card-grid li {
    display: flex;
  }

  .fable-story-card {
    width: 100%;
    min-height: 14rem;
    padding: 0;
    overflow: hidden;
    color: #fff8e8;
    background:
      radial-gradient(circle at 82% 18%, rgba(113, 218, 203, 0.34), transparent 6rem),
      radial-gradient(circle at 18% 82%, rgba(255, 229, 119, 0.28), transparent 7rem),
      linear-gradient(135deg, #462b65 0%, #c1447a 58%, #d17a22 100%);
  }

  .fable-card-image {
    display: block;
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
  }

  .fable-story-card span,
  .fable-story-card strong,
  .fable-story-card p {
    margin-inline: 1.35rem;
  }

  .fable-story-card span:first-of-type {
    margin-top: 1.15rem;
  }

  .fable-story-card p {
    color: rgba(255, 248, 232, 0.94);
  }

  .fable-card-meta {
    display: grid;
    gap: 0.55rem;
    margin: 0.25rem 1.35rem 1.1rem;
    color: rgba(255, 248, 232, 0.94);
  }

  .fable-card-meta div {
    display: grid;
    gap: 0.15rem;
  }

  .fable-card-meta dt {
    font-size: 0.74rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(255, 248, 232, 0.72);
  }

  .fable-card-meta dd {
    margin: 0;
  }

  .fable-story-card .story-card-action {
    margin-bottom: 1.25rem;
  }
</style>
