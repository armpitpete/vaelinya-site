    width: min(100% - 2rem, 860px);
    margin-inline: auto;
    overflow: hidden;
    background: rgba(255, 248, 232, 0.94);
  }

  .story-header-compact,
  .fable-story-content {
    width: min(100%, 680px);
    margin-inline: auto;
  }

  .fable-hero-image {
    width: min(100%, 680px);
    max-width: 680px;
    margin: 1rem auto 0;
  }

  .fable-hero-image img {
    display: block;
    width: 100%;
    height: auto;
  }

  .fable-bottom-links {
    max-width: 32rem;
    margin: 2rem auto 0;
  }

  .fable-story-content p {
    font-size: clamp(1.05rem, 1.45vw, 1.16rem);
  }
</style>