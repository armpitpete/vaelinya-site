---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const description = 'Private graphical command centre for the Vaelinya Twitch bot and site operations.';

const safeFacts = [
  ['Protection', 'Cloudflare Access active'],
  ['Bot service', 'lina-of-vaelinya-bot'],
  ['Bot user', 'lina-bot'],
  ['Server path', '/opt/lina-of-vaelinya-bot'],
  ['Twitch account', 'lina_of_vaelinya'],
  ['Channel', 'merrin_w_dream'],
];

const quickLinks = [
  ['Vaelinya home', '/'],
  ['Story 1', '/read/lina/01-the-bridge-that-sang-back/'],
  ['Stories', '/read/'],
  ['World', '/world/'],
  ['Language', '/language/'],
];
---

<BaseLayout title="Vaelinya Command Centre" description={description} noindex={true}>
  <section class="vaelinya-command-centre" aria-labelledby="command-centre-title" data-command-centre>
    <header class="centre-hero">
      <div>
        <p class="eyebrow">Private control room</p>
        <h1 id="command-centre-title">Vaelinya Command Centre</h1>
        <p class="lede">A clear, graphical dashboard for Lina, the Twitch bot, and the private operational side of Vaelinya.</p>
      </div>

      <div class="bridge-status-card" aria-live="polite">
        <span class="pulse-dot" data-bridge-dot></span>
        <div>
          <strong data-bridge-label>Bridge not connected yet</strong>
          <span data-bridge-detail>Stage A UI is live. Stage B server bridge is still needed for live controls.</span>
        </div>
      </div>
    </header>

    <div class="dashboard-grid">
      <section class="dashboard-card status-command-card" aria-labelledby="bot-status-title">
        <div class="card-heading">
          <p class="card-kicker">Bot state</p>
          <h2 id="bot-status-title">Lina service</h2>
        </div>

        <div class="status-orb status-orb--unknown" data-status-orb aria-hidden="true">
          <span data-status-symbol>?</span>
        </div>

        <div class="state-readout">
          <strong data-service-state>Waiting for bridge</strong>
          <span data-service-detail>Install the Stage B bridge to read live systemd status.</span>
        </div>

        <div class="mini-metric-grid">
          <div class="mini-metric">
            <span>Service</span>
            <strong>lina-of-vaelinya-bot</strong>
          </div>
          <div class="mini-metric">
            <span>Mode</span>
            <strong data-control-mode>Read-only UI</strong>
          </div>
          <div class="mini-metric">
            <span>Last checked</span>
            <strong data-last-checked>Not yet</strong>
          </div>
        </div>
      </section>

      <section class="dashboard-card control-card" aria-labelledby="controls-title">
        <div class="card-heading">
          <p class="card-kicker">Large actions</p>
          <h2 id="controls-title">Bot controls</h2>
          <p>These buttons are wired for Stage B. They stay locked until the private server bridge responds.</p>
        </div>

        <div class="control-grid">
          <button class="control-button control-button--start" type="button" data-action="start" disabled>
            <span class="button-icon">▶</span>
            <span>
              <strong>Start</strong>
              <small>Bring Lina online</small>
            </span>
          </button>

          <button class="control-button control-button--restart" type="button" data-action="restart" disabled>
            <span class="button-icon">↻</span>
            <span>
              <strong>Restart</strong>
              <small>Clean service reload</small>
            </span>
          </button>

          <button class="control-button control-button--stop" type="button" data-action="stop" disabled>
            <span class="button-icon">■</span>
            <span>
              <strong>Stop</strong>
              <small>Take Lina offline</small>
            </span>
          </button>

          <button class="control-button control-button--refresh" type="button" data-action="refresh">
            <span class="button-icon">⟳</span>
            <span>
              <strong>Refresh</strong>
              <small>Check status now</small>
            </span>
          </button>
        </div>

        <p class="action-message" data-action-message>No command has been sent.</p>
      </section>

      <section class="dashboard-card map-card" aria-labelledby="system-map-title">
        <div class="card-heading">
          <p class="card-kicker">Route map</p>
          <h2 id="system-map-title">How control will work</h2>
        </div>

        <div class="flow-map" aria-label="Cloudflare Access protects the page, the Astro page calls a private bridge, the bridge controls systemd, and systemd runs the Twitch bot.">
          <div class="flow-node flow-node--shield">Cloudflare Access</div>
          <div class="flow-arrow">→</div>
          <div class="flow-node flow-node--page">Astro page</div>
          <div class="flow-arrow">→</div>
          <div class="flow-node flow-node--bridge">Server bridge</div>
          <div class="flow-arrow">→</div>
          <div class="flow-node flow-node--bot">Lina bot</div>
        </div>
      </section>

      <section class="dashboard-card locks-card" aria-labelledby="safety-locks-title">
        <div class="card-heading">
          <p class="card-kicker">Safety locks</p>
          <h2 id="safety-locks-title">Never expose these</h2>
        </div>

        <div class="lock-grid">
          <div class="lock-item">.env</div>
          <div class="lock-item">OAuth tokens</div>
          <div class="lock-item">Client secret</div>
          <div class="lock-item">Access token</div>
          <div class="lock-item">Refresh token</div>
          <div class="lock-item">Twitch API credentials</div>
        </div>
      </section>

      <section class="dashboard-card facts-card" aria-labelledby="safe-facts-title">
        <div class="card-heading">
          <p class="card-kicker">Known safe facts</p>
          <h2 id="safe-facts-title">Current setup</h2>
        </div>

        <dl class="fact-list">
          {safeFacts.map(([label, value]) => (
            <div>
              <dt>{label}</dt>
              <dd>{value}</dd>
            </div>
          ))}
        </dl>
      </section>

      <section class="dashboard-card links-card" aria-labelledby="quick-links-title">
        <div class="card-heading">
          <p class="card-kicker">Jump points</p>
          <h2 id="quick-links-title">Useful links</h2>
        </div>

        <div class="quick-link-grid">
          {quickLinks.map(([label, href]) => (
            <a href={href}>{label}</a>
          ))}
        </div>
      </section>

      <section class="dashboard-card logs-card" aria-labelledby="logs-title">
        <div class="card-heading card-heading--row">
          <div>
            <p class="card-kicker">Read-only</p>
            <h2 id="logs-title">Recent bot logs</h2>
          </div>
          <button class="small-button" type="button" data-refresh-logs>Refresh logs</button>
        </div>

        <pre class="log-box" data-log-box>Stage B bridge is not installed yet.
When installed, this panel will show filtered journalctl output only.</pre>
      </section>
    </div>
  </section>

  <script is:inline>
    (() => {
      const root = document.querySelector('[data-command-centre]');
      if (!root) return;

      const API_BASE = '/private/api/lina-command-centre';
      const bridgeDot = root.querySelector('[data-bridge-dot]');
      const bridgeLabel = root.querySelector('[data-bridge-label]');
      const bridgeDetail = root.querySelector('[data-bridge-detail]');
      const statusOrb = root.querySelector('[data-status-orb]');
      const statusSymbol = root.querySelector('[data-status-symbol]');
      const serviceState = root.querySelector('[data-service-state]');
      const serviceDetail = root.querySelector('[data-service-detail]');
      const controlMode = root.querySelector('[data-control-mode]');
      const lastChecked = root.querySelector('[data-last-checked]');
      const actionMessage = root.querySelector('[data-action-message]');
      const logBox = root.querySelector('[data-log-box]');
      const commandButtons = [...root.querySelectorAll('[data-action="start"], [data-action="stop"], [data-action="restart"]')];

      const setBridge = (connected, detail) => {
        bridgeDot.classList.toggle('pulse-dot--good', connected);
        bridgeDot.classList.toggle('pulse-dot--bad', !connected);
        bridgeLabel.textContent = connected ? 'Bridge connected' : 'Bridge not connected yet';
        bridgeDetail.textContent = detail;
        controlMode.textContent = connected ? 'Live controls' : 'Read-only UI';
        commandButtons.forEach((button) => {
          button.disabled = !connected;
        });
      };

      const setServiceState = (state, detail) => {
        const normalized = String(state || 'unknown').toLowerCase();
        statusOrb.className = 'status-orb';
        if (normalized === 'active' || normalized === 'running') {
          statusOrb.classList.add('status-orb--running');
          statusSymbol.textContent = '✓';
          serviceState.textContent = 'Running';
        } else if (normalized === 'inactive' || normalized === 'stopped') {
          statusOrb.classList.add('status-orb--stopped');
          statusSymbol.textContent = '■';
          serviceState.textContent = 'Stopped';
        } else if (normalized === 'failed') {
          statusOrb.classList.add('status-orb--failed');
          statusSymbol.textContent = '!';
          serviceState.textContent = 'Failed';
        } else {
          statusOrb.classList.add('status-orb--unknown');
          statusSymbol.textContent = '?';
          serviceState.textContent = 'Unknown';
        }
        serviceDetail.textContent = detail || 'No live status detail yet.';
        lastChecked.textContent = new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
      };

      const redact = (text) => String(text || '')
        .replace(/(access[_-]?token|refresh[_-]?token|client[_-]?secret|oauth|authorization|bearer)([^\n]*)/gi, '$1 [redacted]')
        .replace(/[A-Za-z0-9_\-]{32,}/g, '[redacted-long-value]');

      const fetchJson = async (url, options = {}) => {
        const response = await fetch(url, {
          credentials: 'same-origin',
          headers: { 'Accept': 'application/json' },
          ...options,
        });
        if (!response.ok) throw new Error(`HTTP ${response.status}`);
        return response.json();
      };

      const refreshStatus = async () => {
        try {
          const data = await fetchJson(`${API_BASE}/status`);
          setBridge(true, 'Private command bridge is responding.');
          setServiceState(data.activeState || data.state, data.detail || data.subState || 'systemd status returned.');
          actionMessage.textContent = 'Status refreshed.';
        } catch (error) {
          setBridge(false, 'Stage B server bridge is still needed for live controls.');
          setServiceState('unknown', 'The Astro page is live, but the control bridge is not installed yet.');
        }
      };

      const refreshLogs = async () => {
        try {
          const data = await fetchJson(`${API_BASE}/logs`);
          const lines = Array.isArray(data.lines) ? data.lines : [];
          logBox.textContent = lines.length ? redact(lines.join('\n')) : 'No recent log lines returned.';
        } catch (error) {
          logBox.textContent = 'Stage B bridge is not installed yet.\nWhen installed, this panel will show filtered journalctl output only.';
        }
      };

      const sendCommand = async (action) => {
        if (action === 'stop' && !confirm('Stop Lina and take the bot offline?')) return;
        if (action === 'restart' && !confirm('Restart Lina now?')) return;

        actionMessage.textContent = `Sending ${action} command...`;
        try {
          const data = await fetchJson(`${API_BASE}/${action}`, { method: 'POST' });
          actionMessage.textContent = data.message || `${action} command sent.`;
          await refreshStatus();
          await refreshLogs();
        } catch (error) {
          actionMessage.textContent = 'Command bridge is not connected yet. Install Stage B before using live controls.';
        }
      };

      root.addEventListener('click', (event) => {
        const button = event.target.closest('[data-action]');
        if (!button) return;
        const action = button.getAttribute('data-action');
        if (action === 'refresh') {
          refreshStatus();
          refreshLogs();
          return;
        }
        sendCommand(action);
      });

      root.querySelector('[data-refresh-logs]')?.addEventListener('click', refreshLogs);
      refreshStatus();
      refreshLogs();
    })();
  </script>
</BaseLayout>

<style>
  :global(.site-main) {
    max-width: none;
    width: 100%;
    padding: 0;
  }

  .vaelinya-command-centre {
    min-height: calc(100vh - 8rem);
    width: 100%;
    padding: clamp(1rem, 3vw, 3rem);
    background:
      radial-gradient(circle at 12% 18%, rgba(181, 122, 255, 0.26), transparent 28rem),
      radial-gradient(circle at 84% 12%, rgba(95, 174, 255, 0.2), transparent 25rem),
      linear-gradient(135deg, #160f25 0%, #22122e 45%, #082134 100%);
    color: #fffaf2;
  }

  .centre-hero {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(18rem, 28rem);
    gap: 1.25rem;
    align-items: end;
    max-width: 1500px;
    margin: 0 auto 1.25rem;
  }

  .eyebrow,
  .card-kicker {
    margin: 0 0 0.45rem;
    color: #d7b6ff;
    font-size: 0.82rem;
    font-weight: 900;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  h1,
  h2 {
    margin: 0;
    line-height: 1;
  }

  h1 {
    max-width: 12ch;
    color: #fffaf2;
    font-size: clamp(3rem, 7vw, 7rem);
    letter-spacing: -0.055em;
  }

  h2 {
    color: #20262c;
    font-size: clamp(1.4rem, 3vw, 2.1rem);
  }

  .lede {
    max-width: 58rem;
    margin: 1rem 0 0;
    color: #eee3f6;
    font-size: clamp(1.1rem, 2vw, 1.45rem);
    line-height: 1.45;
  }

  .bridge-status-card {
    display: flex;
    gap: 1rem;
    align-items: center;
    min-height: 7rem;
    padding: 1.25rem;
    border: 1px solid rgba(255, 250, 242, 0.24);
    border-radius: 24px;
    background: rgba(255, 250, 242, 0.11);
    box-shadow: 0 18px 40px rgba(0, 0, 0, 0.22);
    backdrop-filter: blur(14px);
  }

  .bridge-status-card strong,
  .bridge-status-card span:not(.pulse-dot) {
    display: block;
  }

  .bridge-status-card strong {
    color: #fffaf2;
    font-size: 1.2rem;
  }

  .bridge-status-card span:not(.pulse-dot) {
    margin-top: 0.25rem;
    color: #e9ddf4;
    line-height: 1.35;
  }

  .pulse-dot {
    flex: 0 0 auto;
    width: 1.35rem;
    height: 1.35rem;
    border-radius: 999px;
    background: #d8cbdc;
    box-shadow: 0 0 0 0 rgba(216, 203, 220, 0.5);
  }

  .pulse-dot--good {
    background: #90efb4;
    box-shadow: 0 0 0 0.5rem rgba(144, 239, 180, 0.16);
  }

  .pulse-dot--bad {
    background: #ffcc70;
    box-shadow: 0 0 0 0.5rem rgba(255, 204, 112, 0.16);
  }

  .dashboard-grid {
    display: grid;
    grid-template-columns: repeat(12, minmax(0, 1fr));
    gap: 1rem;
    max-width: 1500px;
    margin: 0 auto;
  }

  .dashboard-card {
    min-height: 14rem;
    padding: clamp(1rem, 2vw, 1.5rem);
    border: 1px solid rgba(255, 250, 242, 0.72);
    border-radius: 28px;
    background: rgba(255, 250, 242, 0.95);
    color: #20262c;
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.22);
  }

  .status-command-card {
    grid-column: span 5;
  }

  .control-card {
    grid-column: span 7;
  }

  .map-card,
  .locks-card {
    grid-column: span 6;
  }

  .facts-card,
  .links-card {
    grid-column: span 6;
  }

  .logs-card {
    grid-column: 1 / -1;
  }

  .card-heading {
    margin-bottom: 1rem;
  }

  .card-heading--row {
    display: flex;
    gap: 1rem;
    align-items: center;
    justify-content: space-between;
  }

  .card-heading p:not(.card-kicker) {
    margin: 0.65rem 0 0;
    color: #5e5662;
    line-height: 1.45;
  }

  .status-orb {
    display: grid;
    place-items: center;
    width: clamp(8rem, 16vw, 13rem);
    height: clamp(8rem, 16vw, 13rem);
    margin: 1rem auto;
    border-radius: 999px;
    font-size: clamp(3rem, 8vw, 6rem);
    font-weight: 900;
    color: #20262c;
  }

  .status-orb--running {
    background: radial-gradient(circle at 35% 25%, #ffffff, #90efb4 55%, #1d9150);
    box-shadow: 0 0 0 0.75rem rgba(144, 239, 180, 0.22), 0 24px 45px rgba(29, 145, 80, 0.32);
  }

  .status-orb--stopped {
    background: radial-gradient(circle at 35% 25%, #ffffff, #ffcc70 55%, #c77618);
    box-shadow: 0 0 0 0.75rem rgba(255, 204, 112, 0.22), 0 24px 45px rgba(199, 118, 24, 0.28);
  }

  .status-orb--failed {
    background: radial-gradient(circle at 35% 25%, #ffffff, #ff8f8f 55%, #b82929);
    box-shadow: 0 0 0 0.75rem rgba(255, 143, 143, 0.22), 0 24px 45px rgba(184, 41, 41, 0.28);
  }

  .status-orb--unknown {
    background: radial-gradient(circle at 35% 25%, #ffffff, #d8cbdc 58%, #83748b);
    box-shadow: 0 0 0 0.75rem rgba(131, 116, 139, 0.15), 0 24px 45px rgba(32, 38, 44, 0.18);
  }

  .state-readout {
    text-align: center;
  }

  .state-readout strong,
  .state-readout span {
    display: block;
  }

  .state-readout strong {
    font-size: 1.6rem;
  }

  .state-readout span {
    margin-top: 0.35rem;
    color: #5e5662;
  }

  .mini-metric-grid,
  .lock-grid,
  .quick-link-grid {
    display: grid;
    gap: 0.75rem;
  }

  .mini-metric-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
    margin-top: 1.25rem;
  }

  .mini-metric,
  .lock-item,
  .quick-link-grid a {
    border: 1px solid #eadfce;
    border-radius: 18px;
    background: #fffaf2;
  }

  .mini-metric {
    padding: 0.85rem;
  }

  .mini-metric span,
  .mini-metric strong {
    display: block;
  }

  .mini-metric span {
    color: #6d6171;
    font-size: 0.78rem;
    font-weight: 800;
    text-transform: uppercase;
  }

  .mini-metric strong {
    margin-top: 0.35rem;
    overflow-wrap: anywhere;
  }

  .control-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0.85rem;
  }

  .control-button {
    display: flex;
    min-height: 8.5rem;
    flex-direction: column;
    justify-content: space-between;
    gap: 1rem;
    padding: 1rem;
    border: 0;
    border-radius: 24px;
    color: #20262c;
    text-align: left;
    cursor: pointer;
    box-shadow: 0 14px 28px rgba(32, 38, 44, 0.12);
  }

  .control-button:disabled {
    cursor: not-allowed;
    filter: grayscale(0.65);
    opacity: 0.58;
  }

  .control-button--start {
    background: linear-gradient(135deg, #b9ffd1, #7ee9a1);
  }

  .control-button--restart {
    background: linear-gradient(135deg, #d9c6ff, #b995ff);
  }

  .control-button--stop {
    background: linear-gradient(135deg, #ffd4d4, #ff9797);
  }

  .control-button--refresh {
    background: linear-gradient(135deg, #d8efff, #9dd8ff);
  }

  .button-icon {
    display: grid;
    place-items: center;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.62);
    font-size: 1.3rem;
    font-weight: 900;
  }

  .control-button strong,
  .control-button small {
    display: block;
  }

  .control-button strong {
    font-size: 1.2rem;
  }

  .control-button small {
    margin-top: 0.25rem;
    color: rgba(32, 38, 44, 0.72);
  }

  .action-message {
    margin: 1rem 0 0;
    color: #5e5662;
    font-weight: 700;
  }

  .flow-map {
    display: grid;
    grid-template-columns: 1fr auto 1fr auto 1fr auto 1fr;
    gap: 0.7rem;
    align-items: center;
    margin-top: 1.25rem;
  }

  .flow-node {
    min-height: 6rem;
    display: grid;
    place-items: center;
    padding: 1rem;
    border-radius: 22px;
    color: #20262c;
    font-weight: 900;
    text-align: center;
  }

  .flow-node--shield {
    background: #d8efff;
  }

  .flow-node--page {
    background: #fff0bd;
  }

  .flow-node--bridge {
    background: #d9c6ff;
  }

  .flow-node--bot {
    background: #b9ffd1;
  }

  .flow-arrow {
    color: #7d4c9e;
    font-size: 2rem;
    font-weight: 900;
  }

  .lock-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
    margin-top: 1rem;
  }

  .lock-item {
    padding: 1rem;
    color: #5a334a;
    font-weight: 900;
    text-align: center;
  }

  .fact-list {
    display: grid;
    gap: 0.7rem;
    margin: 1rem 0 0;
  }

  .fact-list div {
    display: grid;
    grid-template-columns: minmax(8rem, 0.42fr) minmax(0, 1fr);
    gap: 1rem;
    padding: 0.75rem 0;
    border-bottom: 1px solid #eadfce;
  }

  .fact-list dt {
    color: #4d4454;
    font-weight: 900;
  }

  .fact-list dd {
    margin: 0;
    overflow-wrap: anywhere;
  }

  .quick-link-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
    margin-top: 1rem;
  }

  .quick-link-grid a {
    padding: 1rem;
    color: #20262c;
    font-weight: 900;
    text-decoration: none;
  }

  .quick-link-grid a:hover,
  .quick-link-grid a:focus-visible {
    outline: 3px solid rgba(126, 87, 194, 0.45);
    outline-offset: 2px;
  }

  .small-button {
    padding: 0.75rem 1rem;
    border: 0;
    border-radius: 999px;
    background: #20262c;
    color: #fffaf2;
    font-weight: 900;
    cursor: pointer;
  }

  .log-box {
    min-height: 18rem;
    max-height: 34rem;
    overflow: auto;
    margin: 1rem 0 0;
    padding: 1rem;
    border-radius: 20px;
    background: #15121b;
    color: #f4efe8;
    font-size: 0.92rem;
    line-height: 1.55;
    white-space: pre-wrap;
  }

  @media (max-width: 1100px) {
    .centre-hero,
    .dashboard-grid {
      grid-template-columns: 1fr;
    }

    .dashboard-card,
    .status-command-card,
    .control-card,
    .map-card,
    .locks-card,
    .facts-card,
    .links-card,
    .logs-card {
      grid-column: 1 / -1;
    }

    .control-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .flow-map {
      grid-template-columns: 1fr;
    }

    .flow-arrow {
      transform: rotate(90deg);
      text-align: center;
    }
  }

  @media (max-width: 680px) {
    .vaelinya-command-centre {
