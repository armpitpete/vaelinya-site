---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const description = 'Private compact command centre for the Vaelinya Twitch bot and site operations.';

const safeFacts = [
  ['Protection', 'Cloudflare Access'],
  ['Bot service', 'lina-of-vaelinya-bot'],
  ['Bot user', 'lina-bot'],
  ['Server path', '/opt/lina-of-vaelinya-bot'],
  ['Twitch account', 'lina_of_vaelinya'],
  ['Channel', 'merrin_w_dream'],
];

const quickLinks = [
  ['Home', '/'],
  ['Story 1', '/read/lina/01-the-bridge-that-sang-back/'],
  ['Stories', '/read/'],
  ['World', '/world/'],
  ['Language', '/language/'],
];
---
<BaseLayout title="Vaelinya Command Centre" description={description} noindex={true}>
  <section class="command-centre" aria-labelledby="command-centre-title" data-command-centre>
    <header class="console-top panel panel--wide">
      <div class="title-block">
        <p class="eyebrow">Private control room</p>
        <h1 id="command-centre-title">Vaelinya Command Centre</h1>
        <p class="lede">A compact control board for Lina and the private operational side of Vaelinya.</p>
      </div>

      <div class="status-strip" aria-live="polite">
        <div class="status-pill">
          <span class="lamp" data-bridge-dot></span>
          <div>
            <strong data-bridge-label>Checking bridge</strong>
            <span data-bridge-detail>Testing private API.</span>
          </div>
        </div>
        <div class="status-pill">
          <span class="lamp lamp--neutral" data-service-dot></span>
          <div>
            <strong data-service-state>Unknown</strong>
            <span data-service-detail>Waiting for status.</span>
          </div>
        </div>
      </div>
    </header>

    <div class="console-grid">
      <section class="panel service-panel" aria-labelledby="service-title">
        <div class="panel-head">
          <p class="eyebrow">Bot state</p>
          <h2 id="service-title">Lina service</h2>
        </div>

        <div class="meter" data-status-orb aria-hidden="true">
          <span data-status-symbol>?</span>
        </div>

        <div class="mini-readouts">
          <div><span>State</span><strong data-service-state-small>Unknown</strong></div>
          <div><span>Mode</span><strong data-control-mode>Read-only</strong></div>
          <div><span>Checked</span><strong data-last-checked>Not yet</strong></div>
        </div>
      </section>

      <section class="panel controls-panel" aria-labelledby="controls-title">
        <div class="panel-head row-head">
          <div>
            <p class="eyebrow">Controls</p>
            <h2 id="controls-title">Bot controls</h2>
          </div>
          <p class="tiny-note">Start, restart, and stop only unlock after valid bridge JSON.</p>
        </div>

        <div class="switch-bank" role="group" aria-label="Lina service controls">
          <button class="switch switch--start" type="button" data-action="start" disabled>
            <span class="switch-icon">▶</span>
            <strong>Start</strong>
            <small>Online</small>
          </button>
          <button class="switch switch--restart" type="button" data-action="restart" disabled>
            <span class="switch-icon">↻</span>
            <strong>Restart</strong>
            <small>Reload</small>
          </button>
          <button class="switch switch--stop" type="button" data-action="stop" disabled>
            <span class="switch-icon">■</span>
            <strong>Stop</strong>
            <small>Offline</small>
          </button>
        </div>

        <p class="action-message" data-action-message>No command sent.</p>
      </section>

      <section class="panel facts-panel" aria-labelledby="facts-title">
        <div class="panel-head row-head">
          <div>
            <p class="eyebrow">Safe facts</p>
            <h2 id="facts-title">Current setup</h2>
          </div>
        </div>
        <dl class="facts">
          {safeFacts.map(([label, value]) => (
            <div><dt>{label}</dt><dd>{value}</dd></div>
          ))}
        </dl>
      </section>

      <section class="panel links-panel" aria-labelledby="links-title">
        <div class="panel-head">
          <p class="eyebrow">Jump points</p>
          <h2 id="links-title">Useful links</h2>
        </div>
        <div class="link-grid">
          {quickLinks.map(([label, href]) => <a href={href}>{label}</a>)}
        </div>
      </section>

      <section class="panel route-panel" aria-labelledby="route-title">
        <div class="panel-head">
          <p class="eyebrow">Route</p>
          <h2 id="route-title">Control path</h2>
        </div>
        <div class="signal-flow" aria-label="Cloudflare Access protects the page, the page calls the bridge, and the bridge controls the Lina bot.">
          <div>Access</div><span>→</span>
          <div>Page</div><span>→</span>
          <div>Bridge</div><span>→</span>
          <div>Lina</div>
        </div>
      </section>

      <section class="panel locks-panel" aria-labelledby="locks-title">
        <div class="panel-head">
          <p class="eyebrow">Safety</p>
          <h2 id="locks-title">Never expose</h2>
        </div>
        <div class="lock-grid">
          <div>.env</div>
          <div>OAuth tokens</div>
          <div>Client secret</div>
          <div>Access token</div>
          <div>Refresh token</div>
          <div>Twitch API credentials</div>
        </div>
      </section>

      <section class="panel logs-panel" aria-labelledby="logs-title">
        <div class="panel-head row-head">
          <div>
            <p class="eyebrow">Read-only</p>
            <h2 id="logs-title">Recent bot logs</h2>
          </div>
          <button class="mini-button" type="button" data-refresh-logs>Refresh logs</button>
        </div>
        <pre class="log-box" data-log-box>Waiting for bridge.</pre>
      </section>

      <details class="panel diagnostic-panel">
        <summary>
          <span>
            <b>Bridge diagnostic</b>
            <small data-diagnostic-summary>Waiting for first result.</small>
          </span>
          <button class="mini-button" type="button" data-run-diagnostic>Run diagnostic</button>
        </summary>
        <pre class="diagnostic-box" data-diagnostic-box>Not run yet.</pre>
      </details>
    </div>
  </section>

  <script is:inline>
    (() => {
      const root = document.querySelector('[data-command-centre]');
      if (!root) return;

      const API_BASE = '/private/lina-command-centre/api';
      const bridgeDot = root.querySelector('[data-bridge-dot]');
      const bridgeLabel = root.querySelector('[data-bridge-label]');
      const bridgeDetail = root.querySelector('[data-bridge-detail]');
      const serviceDot = root.querySelector('[data-service-dot]');
      const statusOrb = root.querySelector('[data-status-orb]');
      const statusSymbol = root.querySelector('[data-status-symbol]');
      const serviceState = root.querySelector('[data-service-state]');
      const serviceStateSmall = root.querySelector('[data-service-state-small]');
      const serviceDetail = root.querySelector('[data-service-detail]');
      const controlMode = root.querySelector('[data-control-mode]');
      const lastChecked = root.querySelector('[data-last-checked]');
      const actionMessage = root.querySelector('[data-action-message]');
      const diagnosticSummary = root.querySelector('[data-diagnostic-summary]');
      const diagnosticBox = root.querySelector('[data-diagnostic-box]');
      const logBox = root.querySelector('[data-log-box]');
      const commandButtons = [...root.querySelectorAll('[data-action="start"], [data-action="stop"], [data-action="restart"]')];

      const nowStamp = () => new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit', second: '2-digit' });

      const redact = (text) => String(text || '')
        .replace(/(access[_-]?token|refresh[_-]?token|client[_-]?secret|oauth|authorization|bearer)([^\n]*)/gi, '$1 [redacted]')
        .replace(/[A-Za-z0-9_\-.]{32,}/g, '[redacted-long-value]');

      const setLamp = (lamp, state) => {
        lamp.classList.remove('lamp--good', 'lamp--bad', 'lamp--warn', 'lamp--neutral');
        lamp.classList.add(`lamp--${state}`);
      };

      const setBridge = (connected, detail) => {
        setLamp(bridgeDot, connected ? 'good' : 'warn');
        bridgeLabel.textContent = connected ? 'Bridge connected' : 'Bridge not connected';
        bridgeDetail.textContent = detail;
        controlMode.textContent = connected ? 'Live controls' : 'Read-only';
        commandButtons.forEach((button) => { button.disabled = !connected; });
      };

      const setServiceState = (state, detail) => {
        const normalized = String(state || 'unknown').toLowerCase();
        statusOrb.className = 'meter';
        let label = 'Unknown';
        let symbol = '?';
        let lampState = 'neutral';

        if (normalized === 'active' || normalized === 'running') {
          statusOrb.classList.add('meter--running');
          label = 'Running';
          symbol = '✓';
          lampState = 'good';
        } else if (normalized === 'inactive' || normalized === 'stopped') {
          statusOrb.classList.add('meter--stopped');
          label = 'Stopped';
          symbol = '■';
          lampState = 'warn';
        } else if (normalized === 'failed') {
          statusOrb.classList.add('meter--failed');
          label = 'Failed';
          symbol = '!';
          lampState = 'bad';
        } else if (normalized === 'activating' || normalized === 'deactivating') {
          statusOrb.classList.add('meter--transition');
          label = normalized === 'activating' ? 'Starting' : 'Stopping';
          symbol = '…';
          lampState = 'warn';
        } else {
          statusOrb.classList.add('meter--unknown');
        }

        statusSymbol.textContent = symbol;
        serviceState.textContent = label;
        serviceStateSmall.textContent = label;
        serviceDetail.textContent = detail || 'No detail yet.';
        setLamp(serviceDot, lampState);
        lastChecked.textContent = nowStamp();
      };

      const inspectFetch = async (path, options = {}) => {
        const url = `${API_BASE}${path}${path.includes('?') ? '&' : '?'}_debug=${Date.now()}`;
        const startedAt = nowStamp();
        try {
          const response = await fetch(url, {
            credentials: 'include',
            cache: 'no-store',
            redirect: 'follow',
            headers: { 'Accept': 'application/json, text/plain, */*' },
            ...options,
          });

          const contentType = response.headers.get('content-type') || '(none)';
          const responseUrl = response.url || url;
          const text = await response.text();
          let json = null;
          let jsonError = '';

          try {
            json = JSON.parse(text);
          } catch (error) {
            jsonError = error.message || 'JSON parse failed';
          }

          return {
            ok: response.ok,
            status: response.status,
            statusText: response.statusText,
            contentType,
            responseUrl,
            requestedUrl: url,
            startedAt,
            receivedAt: nowStamp(),
            json,
            jsonError,
            textPreview: redact(text).slice(0, 700),
          };
        } catch (error) {
          return {
            ok: false,
            status: 'FETCH_ERROR',
            statusText: error.message || String(error),
            contentType: '(none)',
            responseUrl: url,
            requestedUrl: url,
            startedAt,
            receivedAt: nowStamp(),
            json: null,
            jsonError: 'Network/fetch error',
            textPreview: '',
          };
        }
      };

      const showDiagnostic = (result) => {
        const bodyType = result.json ? 'JSON' : 'not JSON';
        diagnosticSummary.textContent = `HTTP ${result.status} · ${result.contentType} · ${bodyType}`;
        diagnosticBox.textContent = redact([
          `Requested: ${result.requestedUrl}`,
          `Response URL: ${result.responseUrl}`,
          `Started: ${result.startedAt}`,
          `Received: ${result.receivedAt}`,
          `HTTP status: ${result.status}`,
          `Content-Type: ${result.contentType}`,
          `JSON parsed: ${result.json ? 'yes' : 'no'}`,
          result.jsonError ? `JSON error: ${result.jsonError}` : '',
          '',
          'Returned body preview:',
          result.json ? JSON.stringify(result.json, null, 2) : result.textPreview,
        ].filter(Boolean).join('\n'));
      };

      const runStatus = async () => {
        const result = await inspectFetch('/status');
        showDiagnostic(result);

        if (result.ok && result.json && result.json.ok !== false) {
          setBridge(true, 'Private command bridge returned valid JSON.');
          setServiceState(result.json.activeState || result.json.state, result.json.detail || result.json.subState || 'systemd status returned.');
          actionMessage.textContent = 'Status refreshed.';
          return result.json;
        }

        const reason = result.json?.message || result.jsonError || `HTTP ${result.status}`;
        setBridge(false, reason);
        setServiceState('unknown', reason);
        actionMessage.textContent = `Bridge diagnostic failed: ${reason}`;
        return null;
      };

      const refreshLogs = async () => {
        const result = await inspectFetch('/logs');
        if (result.ok && result.json) {
          const lines = Array.isArray(result.json.lines) ? result.json.lines : [];
          logBox.textContent = lines.length ? redact(lines.join('\n')) : 'No recent log lines returned.';
          return;
        }
        logBox.textContent = `Logs unavailable. See diagnostic.\nHTTP ${result.status} · ${result.contentType}`;
      };

      const settleAfterCommand = async () => {
        for (let i = 0; i < 6; i += 1) {
          await new Promise((resolve) => setTimeout(resolve, i === 0 ? 600 : 1600));
          await runStatus();
        }
        await refreshLogs();
      };

      const sendCommand = async (action) => {
        if (action === 'stop' && !confirm('Stop Lina and take the bot offline?')) return;
        if (action === 'restart' && !confirm('Restart Lina now?')) return;

        actionMessage.textContent = `Sending ${action} command...`;
        const result = await inspectFetch(`/${action}`, { method: 'POST' });
        showDiagnostic(result);

        if (result.ok && result.json) {
          actionMessage.textContent = result.json.message || `${action} command sent.`;
          await settleAfterCommand();
          return;
        }

        actionMessage.textContent = `Command failed: HTTP ${result.status}. See diagnostic.`;
      };

      root.addEventListener('click', (event) => {
        const diagnosticButton = event.target.closest('[data-run-diagnostic]');
        if (diagnosticButton) {
          event.preventDefault();
          runStatus();
          return;
        }

        const button = event.target.closest('[data-action]');
        if (!button) return;
        sendCommand(button.getAttribute('data-action'));
      });

      root.querySelector('[data-refresh-logs]')?.addEventListener('click', refreshLogs);
      runStatus();
      refreshLogs();
    })();
  </script>
</BaseLayout>

<style>
  :global(.site-main) {
    max-width: none;
    width: 100%;
    padding: 0;
  }

  .command-centre {
    --board: #b8c2c7;
    --board-dark: #7f8e95;
    --panel: #cbd3d6;
    --panel-light: #e4eaec;
    --ink: #17232a;
    --muted: #52636b;
    --line: rgba(54, 70, 78, 0.22);
    --red: #d65f5b;
    --amber: #e1b44c;
    --green: #4fc07a;
    --blue: #6da5bd;
    min-height: calc(100vh - 8rem);
    padding: clamp(0.75rem, 2vw, 1.35rem);
    background:
      radial-gradient(circle at 15% 8%, rgba(255, 255, 255, 0.45), transparent 28rem),
      linear-gradient(135deg, #151021 0%, #261836 45%, #0b2531 100%);
    color: var(--ink);
    font-family: Futura, 'Avenir Next', 'Gill Sans', 'Century Gothic', system-ui, sans-serif;
    font-size: 0.86rem;
  }

  .console-top,
  .console-grid {
    max-width: 1380px;
    margin: 0 auto;
  }

  .console-grid {
    display: grid;
    grid-template-columns: repeat(12, minmax(0, 1fr));
    gap: 0.7rem;
    margin-top: 0.7rem;
  }

  .panel {
    border: 1px solid rgba(255, 255, 255, 0.55);
    border-radius: 20px;
    background: linear-gradient(145deg, #d7dfe2, #b9c4c9);
    box-shadow:
      10px 10px 24px rgba(5, 9, 14, 0.34),
      -6px -6px 18px rgba(255, 255, 255, 0.18),
      inset 1px 1px 0 rgba(255, 255, 255, 0.65),
      inset -2px -2px 8px rgba(62, 76, 84, 0.18);
  }

  .panel--wide {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(20rem, 35rem);
    gap: 1rem;
    align-items: end;
    padding: clamp(1rem, 2vw, 1.4rem);
  }

  .service-panel,
  .facts-panel,
  .links-panel,
  .route-panel,
  .locks-panel,
  .controls-panel,
  .logs-panel,
  .diagnostic-panel {
    padding: 1rem;
  }

  .service-panel { grid-column: span 4; }
  .controls-panel { grid-column: span 8; }
  .facts-panel,
  .links-panel,
  .route-panel,
  .locks-panel { grid-column: span 6; }
  .logs-panel,
  .diagnostic-panel { grid-column: 1 / -1; }

  .title-block { min-width: 0; }

  .eyebrow {
    margin: 0 0 0.35rem;
    color: #44535a;
    font-size: 0.68rem;
    font-weight: 900;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  h1,
  h2 {
    margin: 0;
    color: var(--ink);
    line-height: 0.95;
    letter-spacing: -0.04em;
  }

  h1 {
    max-width: none;
    font-size: clamp(2rem, 5vw, 4.6rem);
  }

  h2 { font-size: clamp(1.05rem, 2vw, 1.55rem); }

  .lede {
    max-width: 45rem;
    margin: 0.65rem 0 0;
    color: var(--muted);
    font-size: 0.98rem;
    line-height: 1.35;
  }

  .status-strip {
    display: grid;
    gap: 0.55rem;
  }

  .status-pill,
  .mini-readouts div,
  .facts div,
  .link-grid a,
  .lock-grid div,
  .signal-flow div {
    background: linear-gradient(145deg, #edf2f3, #c0cacf);
    box-shadow:
      inset 2px 2px 5px rgba(255, 255, 255, 0.85),
      inset -3px -3px 7px rgba(75, 91, 100, 0.18),
      4px 4px 10px rgba(28, 36, 44, 0.12);
  }

  .status-pill {
    display: flex;
    gap: 0.7rem;
    align-items: center;
    min-height: 3.6rem;
    padding: 0.75rem 0.85rem;
    border: 1px solid rgba(255, 255, 255, 0.72);
    border-radius: 16px;
  }

  .status-pill strong,
  .status-pill span:not(.lamp) { display: block; }
  .status-pill strong { font-size: 0.96rem; }
  .status-pill span:not(.lamp) { margin-top: 0.15rem; color: var(--muted); font-size: 0.78rem; }

  .lamp {
    flex: 0 0 auto;
    width: 1.05rem;
    height: 1.05rem;
    border-radius: 999px;
    background: #9da9ad;
    box-shadow:
      inset 0 2px 4px rgba(255, 255, 255, 0.8),
      inset 0 -3px 5px rgba(0, 0, 0, 0.25),
      0 0 0 0.35rem rgba(255, 255, 255, 0.24);
  }

  .lamp--good { background: var(--green); box-shadow: inset 0 2px 4px rgba(255, 255, 255, 0.8), inset 0 -3px 5px rgba(0, 0, 0, 0.2), 0 0 13px rgba(79, 192, 122, 0.8); }
  .lamp--warn { background: var(--amber); box-shadow: inset 0 2px 4px rgba(255, 255, 255, 0.8), inset 0 -3px 5px rgba(0, 0, 0, 0.2), 0 0 13px rgba(225, 180, 76, 0.75); }
  .lamp--bad { background: var(--red); box-shadow: inset 0 2px 4px rgba(255, 255, 255, 0.8), inset 0 -3px 5px rgba(0, 0, 0, 0.2), 0 0 13px rgba(214, 95, 91, 0.75); }
  .lamp--neutral { background: #9da9ad; }

  .panel-head { margin-bottom: 0.7rem; }
  .row-head { display: flex; gap: 0.75rem; align-items: start; justify-content: space-between; }
  .tiny-note { max-width: 24rem; margin: 0; color: var(--muted); font-size: 0.78rem; line-height: 1.35; }

  .meter {
    display: grid;
    place-items: center;
    width: clamp(5.4rem, 10vw, 7.4rem);
    height: clamp(5.4rem, 10vw, 7.4rem);
    margin: 0.55rem auto 0.75rem;
    border-radius: 999px;
    color: var(--ink);
    font-size: clamp(2rem, 4vw, 3.8rem);
    font-weight: 900;
    background: radial-gradient(circle at 33% 25%, #f8fbfb, #aebbc0 58%, #687a82);
    box-shadow:
      8px 8px 20px rgba(18, 28, 34, 0.28),
      -7px -7px 18px rgba(255, 255, 255, 0.35),
      inset 4px 4px 10px rgba(255, 255, 255, 0.72),
      inset -7px -7px 16px rgba(69, 83, 91, 0.28);
  }

  .meter--running { background: radial-gradient(circle at 33% 25%, #f8fbfb, #83e9ad 58%, #23884f); }
  .meter--stopped,
  .meter--transition { background: radial-gradient(circle at 33% 25%, #fffdf2, #e9bf5c 58%, #9b6a17); }
  .meter--failed { background: radial-gradient(circle at 33% 25%, #fff4f4, #ea7773 58%, #9f2d2a); }
  .meter--unknown { background: radial-gradient(circle at 33% 25%, #f8fbfb, #b9c4c9 58%, #687a82); }

  .mini-readouts,
  .switch-bank,
  .facts,
  .link-grid,
  .lock-grid {
    display: grid;
    gap: 0.55rem;
  }

  .mini-readouts { grid-template-columns: repeat(3, minmax(0, 1fr)); }
  .mini-readouts div { min-height: 3.3rem; padding: 0.55rem; border-radius: 13px; }
  .mini-readouts span,
  .mini-readouts strong { display: block; }
  .mini-readouts span { color: var(--muted); font-size: 0.62rem; font-weight: 900; letter-spacing: 0.08em; text-transform: uppercase; }
  .mini-readouts strong { margin-top: 0.25rem; font-size: 0.78rem; overflow-wrap: anywhere; }

  .switch-bank { grid-template-columns: repeat(3, minmax(0, 1fr)); }
  .switch {
    min-height: 5.2rem;
    padding: 0.7rem;
    border: 1px solid rgba(255, 255, 255, 0.75);
    border-radius: 17px;
    color: var(--ink);
    text-align: left;
    cursor: pointer;
    background: #c9d3d7;
    box-shadow:
      7px 7px 15px rgba(26, 35, 42, 0.2),
      -5px -5px 12px rgba(255, 255, 255, 0.26),
      inset 1px 1px 0 rgba(255, 255, 255, 0.7);
  }
  .switch:active { box-shadow: inset 5px 5px 12px rgba(26, 35, 42, 0.2), inset -4px -4px 10px rgba(255, 255, 255, 0.45); transform: translateY(1px); }
  .switch:disabled { cursor: not-allowed; filter: grayscale(0.7); opacity: 0.55; }
  .switch--start { background: linear-gradient(145deg, #a7f0bf, #61c987); }
  .switch--restart { background: linear-gradient(145deg, #d1baf2, #a888d8); }
  .switch--stop { background: linear-gradient(145deg, #f7c0bf, #e98585); }
  .switch-icon { display: grid; place-items: center; width: 1.75rem; height: 1.75rem; border-radius: 999px; background: rgba(255, 255, 255, 0.62); font-weight: 900; }
  .switch strong,
  .switch small { display: block; }
  .switch strong { margin-top: 0.45rem; font-size: 1rem; }
  .switch small { margin-top: 0.1rem; color: rgba(23, 35, 42, 0.68); font-size: 0.72rem; }

  .action-message,
  .diagnostic-panel small { color: var(--muted); font-weight: 800; }
  .action-message { margin: 0.65rem 0 0; font-size: 0.82rem; }

  .facts { margin: 0; }
  .facts div { display: grid; grid-template-columns: minmax(6rem, 0.42fr) minmax(0, 1fr); gap: 0.6rem; padding: 0.55rem 0.65rem; border-radius: 12px; }
