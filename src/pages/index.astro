---
import BaseLayout from '../layouts/BaseLayout.astro';

const description = 'A colourful, illustrated, learnable story world where readers can begin with stories, then explore world, language, and artefacts.';
const site = Astro.site ?? new URL('https://vaelinya.uk');

const webSiteJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Vaelinya',
  description,
  url: new URL('/', site).toString(),
  inLanguage: 'en',
};
---
<BaseLayout title="Vaelinya is your next adventure" description={description} jsonLd={webSiteJsonLd}>
  <link rel="stylesheet" href="/styles/home-hero-image-v20260522.css?v=first-path-lina-02" />
  <section class="hero hero-illustrated threshold-hero">
    <div class="hero-copy">
      <p class="eyebrow">A story world</p>
      <h1>Welcome to Vaelinya.</h1>
      <p>A colourful, illustrated, learnable story world of brave children, living words, strange places, meaningful things, and careful remembering.</p>
      <p class="threshold-line">Choose a door. Begin.</p>
    </div>
    <figure class="hero-art hero-art-image">
      <img
        src="/images/begin-the-journey.webp?v=2026-05-22-tight-02"
        alt="A glowing stone path leading towards a bright gateway under a starry Vaelinya sky."
        width="1600"
        height="1200"
        loading="eager"
        decoding="async"
      />
    </figure>
  </section>

  <section class="door-intro" aria-labelledby="door-intro-title">
    <p class="eyebrow">Four doors</p>
    <h2 id="door-intro-title">Choose how you want to enter.</h2>
    <p>Start with a story, step into the world, learn a word, or look closely at an artefact. You do not need to understand everything before you begin.</p>
  </section>

  <section class="door-grid" aria-label="Four doorways into Vaelinya">
    <a class="door-card door-card--read" href="/read/" aria-label="Read the stories">
      <div class="door-card__visual" aria-hidden="true">
        <div class="door-card__shape"><span>✦</span></div>
      </div>
      <div class="door-card__content">
        <p class="door-card__label">Read</p>
        <h3>Read the stories</h3>
        <p>Start with stories and meet the children of Vaelinya.</p>
      </div>
    </a>

    <a class="door-card door-card--world" href="/world/" aria-label="Explore the world">
      <div class="door-card__visual" aria-hidden="true">
        <div class="door-card__shape"><span>◎</span></div>
      </div>
      <div class="door-card__content">
        <p class="door-card__label">World</p>
        <h3>Explore the world</h3>
        <p>Explore places, people, customs, and the living shape of the world.</p>
      </div>
    </a>

    <a class="door-card door-card--language" href="/language/" aria-label="Learn the language">
      <div class="door-card__visual" aria-hidden="true">
        <div class="door-card__shape"><span>⌁</span></div>
      </div>
      <div class="door-card__content">
        <p class="door-card__label">Language</p>
        <h3>Learn the language</h3>
        <p>Learn Vaelinya words one small family at a time.</p>
      </div>
    </a>

    <a class="door-card door-card--artefacts" href="/artefacts/" aria-label="Discover artefacts">
      <div class="door-card__visual" aria-hidden="true">
        <div class="door-card__shape"><span>◇</span></div>
      </div>
      <div class="door-card__content">
        <p class="door-card__label">Artefacts</p>
        <h3>Discover artefacts</h3>
        <p>See symbols, objects, marks, and things made inside the world.</p>
      </div>
    </a>
  </section>

  <section class="panel lina-greeting-panel" aria-labelledby="lina-greeting-title">
    <div class="lina-greeting-mark" aria-hidden="true"><span>✦</span></div>
    <div>
      <p class="eyebrow">Lina greeting</p>
      <h2 id="lina-greeting-title">Lina says hello</h2>
      <p>Lina says hello. Her Vaelinya greeting will be added when the word is ready.</p>
      <p class="audio-policy-note">Sound will never play by itself. When audio is added, you will press Play first.</p>
      <p><a class="button secondary" href="/read/lina/">Meet Lina</a></p>
    </div>
  </section>

  <section class="panel first-path-panel" aria-labelledby="first-path-title">
    <div class="first-path-image" aria-hidden="true"></div>
    <div class="first-path-copy">
      <p class="eyebrow">First path</p>
      <h2 id="first-path-title">Start with Lina.</h2>
      <p>Read one story first. Then follow any place, word, symbol, or object that catches your attention.</p>
      <a class="button first-path-link" href="/read/lina/">Open Lina’s stories</a>
    </div>
  </section>
</BaseLayout>
