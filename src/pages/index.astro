---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Vaelinya is your next adventure" description="A colourful story world of memory, weather, borders, childhood, ritual, language, song, care, and brave attention.">
  <section class="hero">
    <p class="eyebrow">Welcome to Vaelinya</p>
    <h1>Vaelinya is your next adventure.</h1>
    <p>A colourful story world of memory, weather, borders, childhood, ritual, language, song, care, and brave attention.</p>
  </section>

  <section class="door-grid" aria-label="Four doorways into Vaelinya">
    <a class="door-card read" href="/read/">
      <span>Read</span>
      <strong>Read the stories</strong>
      <p>Begin with Lina’s eight stories, then meet the other children.</p>
    </a>
    <a class="door-card world" href="/world/">
      <span>World</span>
      <strong>Explore the world</strong>
      <p>Find the Rim, the Rimaeri, the Warm Remembering, and strange places.</p>
    </a>
    <a class="door-card language" href="/language/">
      <span>Language</span>
      <strong>Learn the language</strong>
      <p>Start with small words, sounds, names, and gentle practice.</p>
    </a>
    <a class="door-card artefacts" href="/artefacts/">
      <span>Artefacts</span>
      <strong>Discover artefacts</strong>
      <p>Maps, symbols, chant cards, story objects, and printables.</p>
    </a>
  </section>

  <section class="panel">
    <h2>Start here</h2>
    <p>New to Vaelinya? Begin with the Start page, or go straight to Lina’s first repaired story.</p>
    <p><a class="button" href="/start/">Start here</a> <a class="button secondary" href="/read/lina/01-the-bridge-that-sang-back/">Read Story 01</a></p>
  </section>
</BaseLayout>
