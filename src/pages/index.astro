---
import BaseLayout from '../layouts/BaseLayout.astro';
import VisualCallout from '../components/VisualCallout.astro';
---
<BaseLayout title="Vaelinya is your next adventure" description="A colourful story world of remembrance, weather, borders, childhood, ritual, language, song, care, and brave attention.">
  <section class="hero hero-illustrated">
    <div class="hero-copy">
      <p class="eyebrow">A story world</p>
      <h1>Welcome to Vaelinya.</h1>
      <p>A colourful story world of remembrance, weather, borders, childhood, ritual, language, song, care, and brave attention.</p>
    </div>
    <div class="hero-art" aria-label="Illustrated symbol of a glowing bridge, mist, stars, and paths into Vaelinya">
      <div class="sun-orb"></div>
      <div class="map-line line-one"></div>
      <div class="map-line line-two"></div>
      <div class="bridge-arc"></div>
      <div class="mist-band"></div>
      <div class="star star-one">✦</div>
      <div class="star star-two">✧</div>
      <div class="figure-dot"></div>
      <p>begin the journey</p>
    </div>
  </section>

  <VisualCallout
    eyebrow="First path"
    title="Begin with one story, then follow what shines."
    text="Vaelinya is easiest to enter through a small choice: read a story, notice a symbol, learn a word, or step onto the Rim. You do not need the whole world before you start."
    href="/read/lina/"
    linkText="Open Lina’s stories"
    symbol="✦"
    tone="read"
  />

  <section class="door-grid" aria-label="Four doorways into Vaelinya">
    <a class="door-card read" href="/read/">
      <span class="symbol-circle">✦</span>
      <span>Read</span>
      <strong>Read the stories</strong>
      <p>Begin with Lina’s eight stories, then meet the other children.</p>
    </a>
    <a class="door-card world" href="/world/">
      <span class="symbol-circle">◎</span>
      <span>World</span>
      <strong>Explore the world</strong>
      <p>Find the Rim, the Rimaeri, the Warm Remembering, and strange places.</p>
    </a>
    <a class="door-card language" href="/language/">
      <span class="symbol-circle">⌁</span>
      <span>Language</span>
      <strong>Learn the language</strong>
      <p>Start with small words, sounds, names, and gentle practice.</p>
    </a>
    <a class="door-card artefacts" href="/artefacts/">
      <span class="symbol-circle">◇</span>
      <span>Artefacts</span>
      <strong>Discover artefacts</strong>
      <p>Maps, symbols, chant cards, story objects, and printables.</p>
    </a>
  </section>

  <section class="panel next-step-panel">
    <h2>Choose your first path</h2>
    <p>Stories are the gentlest start. The other branches deepen the world when you want to explore further.</p>
    <p><a class="button" href="/read/">Begin with stories</a> <a class="button secondary" href="/start/">Open the guide</a></p>
  </section>
</BaseLayout>
