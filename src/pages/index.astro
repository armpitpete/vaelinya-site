---
import BaseLayout from '../layouts/BaseLayout.astro';
import VaelinyaLiveHero from '../components/VaelinyaLiveHero.astro';

const description = 'Vaelinya is a colourful story world on a planet on the far side of the Sun, with two moons, gentle magic, brave children, and living words.';
const site = Astro.site ?? new URL('https://vaelinya.uk');

const webSiteJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Vaelinya',
  description,
  url: new URL('/', site).toString(),
  inLanguage: 'en',
};
---
<BaseLayout title="Vaelinya is your next adventure" description={description} jsonLd={webSiteJsonLd}>
  <link rel="stylesheet" href="/styles/home-hero-image-v20260522.css?v=2026-06-06-live-bg-01" />
  <link rel="stylesheet" href="/styles/home-door-hover-v20260525.css?v=2026-05-25-door-intro-centre-03" />
  <div class="home-page">
    <VaelinyaLiveHero />

    <section class="panel home-intro-panel" aria-labelledby="home-intro-title">
      <p class="eyebrow">What is Vaelinya?</p>
      <h2 id="home-intro-title">Vaelinya is a colourful story world.</h2>
      <p>Vaelinya is a planet on the far side of the Sun, with two moons in its sky.</p>
      <p>People, animals, plants, words, songs, and places are different there. Everyone has their own way of noticing, feeling, moving, speaking, remembering, and understanding.</p>
      <p>Kindness is part of everyday life. People are given time, space, clear words, and gentle ways to begin.</p>
      <p>On this website, you can read stories, meet Lina and her friends, explore the world, learn Vaelinya words, hear songs, and find artefacts from the stories.</p>
      <div class="home-main-invite">
        <a class="button" href="/start/">Say hello to Lina</a>
        <span>Lina will greet you and show you the first gentle path into Vaelinya.</span>
      </div>
    </section>

    <section class="door-intro" aria-labelledby="door-intro-title" style="display: flex; flex-direction: column; align-items: center; text-align: center;">
      <p class="eyebrow" style="text-align: center; margin-left: auto; margin-right: auto;">After you begin</p>
      <h2 id="door-intro-title" style="text-align: center; margin-left: auto; margin-right: auto;">Choose a door.</h2>
      <p class="door-intro-copy" style="max-width: 46rem; width: 100%; margin-left: auto; margin-right: auto; text-align: center; line-height: 1.45;">
        <span style="display: block; width: 100%; text-align: center;">Once Lina has shown you the first path, you can keep reading, explore the world, learn the language, or follow artefacts and hidden things.</span>
      </p>
    </section>

    <section class="door-grid" aria-label="Four doorways into Vaelinya">
      <a class="door-card door-card--read" href="/read/" aria-label="Read the stories">
        <div class="door-card__visual" aria-hidden="true">
          <div class="door-card__shape"><span>✦</span></div>
        </div>
        <div class="door-card__content">
          <p class="door-card__label">Stories</p>
          <h3>Continue the stories</h3>
          <p>Meet the children of Vaelinya one story at a time.</p>
        </div>
      </a>

      <a class="door-card door-card--world" href="/world/" aria-label="Explore the world">
        <div class="door-card__visual" aria-hidden="true">
          <div class="door-card__shape"><span>◎</span></div>
        </div>
        <div class="door-card__content">
          <p class="door-card__label">World</p>
          <h3>Explore the world</h3>
          <p>Browse places, people, customs, objects, and symbols.</p>
        </div>
      </a>

      <a class="door-card door-card--language" href="/language/" aria-label="Learn the language">
        <div class="door-card__visual" aria-hidden="true">
          <div class="door-card__shape"><span>⌁</span></div>
        </div>
        <div class="door-card__content">
          <p class="door-card__label">Language</p>
          <h3>Learn the language</h3>
          <p>Learn one small family of Vaelinya words at a time.</p>
        </div>
      </a>

      <a class="door-card door-card--start" href="/artefacts/" aria-label="Find artefacts from the stories">
        <div class="door-card__visual" aria-hidden="true">
          <div class="door-card__shape"><span>✦</span></div>
        </div>
        <div class="door-card__content">
          <p class="door-card__label">Artefacts</p>
          <h3>Find artefacts</h3>
          <p>Find symbols, maps, objects, songs, and hidden things from the stories.</p>
        </div>
      </a>
    </section>
  </div>
</BaseLayout>
