---
import BaseLayout from '../layouts/BaseLayout.astro';
import VaelinyaLiveHero from '../components/VaelinyaLiveHero.astro';

const description = 'A colourful, illustrated, learnable story world where readers can begin with a simple doorway, then follow stories, world, and language.';
const site = Astro.site ?? new URL('https://vaelinya.uk');

const webSiteJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Vaelinya',
  description,
  url: new URL('/', site).toString(),
  inLanguage: 'en',
};
---
<BaseLayout title="Vaelinya is your next adventure" description={description} jsonLd={webSiteJsonLd}>
  <link rel="stylesheet" href="/styles/home-hero-image-v20260522.css?v=2026-05-22-tight-02" />
  <link rel="stylesheet" href="/styles/home-door-hover-v20260525.css?v=2026-05-25-door-intro-centre-03" />
  <div class="home-page">
    <VaelinyaLiveHero />

    <section class="door-intro" aria-labelledby="door-intro-title" style="display: flex; flex-direction: column; align-items: center; text-align: center;">
      <p class="eyebrow" style="text-align: center; margin-left: auto; margin-right: auto;">Four doors</p>
      <h2 id="door-intro-title" style="text-align: center; margin-left: auto; margin-right: auto;">Choose how you want to enter.</h2>
      <p class="door-intro-copy" style="max-width: 46rem; width: 100%; margin-left: auto; margin-right: auto; text-align: center; line-height: 1.45;">
        <span style="display: block; width: 100%; text-align: center;">Begin with Lina’s first story, then read on, step into the world, or learn a word.</span>
        <span style="display: block; width: 100%; text-align: center;">You do not need to understand everything before you begin.</span>
      </p>
    </section>

    <section class="door-grid" aria-label="Four doorways into Vaelinya">
      <a class="door-card door-card--start" href="/read/lina/01-the-bridge-that-sang-back/" aria-label="Read Story 1: The Bridge That Sang Back">
        <div class="door-card__visual" aria-hidden="true">
          <div class="door-card__shape"><span>✦</span></div>
        </div>
        <div class="door-card__content">
          <p class="door-card__label">Start here</p>
          <h3>Read Story 1</h3>
          <p>Begin with Lina and The Bridge That Sang Back.</p>
        </div>
      </a>

      <a class="door-card door-card--read" href="/read/" aria-label="Read the stories">
        <div class="door-card__visual" aria-hidden="true">
          <div class="door-card__shape"><span>✦</span></div>
        </div>
        <div class="door-card__content">
          <p class="door-card__label">Stories</p>
          <h3>Read the stories</h3>
          <p>Meet the children of Vaelinya one story at a time.</p>
        </div>
      </a>

      <a class="door-card door-card--world" href="/world/" aria-label="Explore the world">
        <div class="door-card__visual" aria-hidden="true">
          <div class="door-card__shape"><span>◎</span></div>
        </div>
        <div class="door-card__content">
          <p class="door-card__label">World</p>
          <h3>Explore the world</h3>
          <p>Browse places, people, customs, objects, and symbols.</p>
        </div>
      </a>

      <a class="door-card door-card--language" href="/language/" aria-label="Learn the language">
        <div class="door-card__visual" aria-hidden="true">
          <div class="door-card__shape"><span>⌁</span></div>
        </div>
        <div class="door-card__content">
          <p class="door-card__label">Language</p>
          <h3>Learn the language</h3>
          <p>Learn Vaelinya words one small family at a time.</p>
        </div>
      </a>
    </section>

    <section class="panel lina-greeting-panel" aria-labelledby="lina-greeting-title">
      <figure class="lina-greeting-image">
        <img
          src="/images/lina-says-hello-card.jpg?v=2026-05-25-hello-real-01"
          alt="Lina smiles and raises one hand in greeting."
          width="1600"
          height="900"
          loading="lazy"
          decoding="async"
        />
      </figure>
      <div class="lina-greeting-copy">
        <p class="eyebrow">Lina greeting</p>
        <h2 id="lina-greeting-title">Lina says hello</h2>
        <p>“Hello. You can begin slowly.”</p>
        <p>Lina is the first person many readers meet in Vaelinya. She notices small things, listens carefully, and helps the world open without rushing.</p>
        <p><a class="button secondary" href="/read/lina/01-the-bridge-that-sang-back/">Read Story 1</a></p>
      </div>
    </section>

    <section class="panel first-path-panel" aria-labelledby="first-path-title">
      <div class="first-path-image" aria-hidden="true"></div>
      <div class="first-path-copy">
        <p class="eyebrow">First path</p>
        <h2 id="first-path-title">Start with Lina.</h2>
        <p>Read one story first. Then follow any place, word, symbol, or object that catches your attention.</p>
        <a class="button first-path-link" href="/read/lina/01-the-bridge-that-sang-back/">Read Story 1: The Bridge That Sang Back</a>
      </div>
    </section>
  </div>
</BaseLayout>
