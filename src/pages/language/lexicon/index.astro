---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const words = [
  {
    word: 'aelok',
    vaelinya_form: 'aelok',
    meaning: 'home-place',
    pronunciation: 'AY-lok',
    pronunciation_ipa: '/ˈeɪ.lɒk/',
    what: 'A place where someone can settle without guarding themselves.',
    richer: 'It is more than shelter. It is a place where the body and mind can stop bracing.',
    use: 'Use it for a room, home, corner, settlement, or gathering-place that lets someone feel inwardly safe.',
    not_for: 'Do not use it for ordinary buildings, legal property, ownership, or belonging in general.',
    example: 'In her small painted kitchen, he found aelok before he found the courage to speak.',
    plain_english: 'In her kitchen, he found a true home-place before he found words.',
  },
  {
    word: 'meras',
    vaelinya_form: 'meras',
    meaning: 'belonging',
    pronunciation: 'MEH-ras',
    pronunciation_ipa: '/ˈmɛ.ræs/',
    what: 'The felt condition of being rightly placed among others.',
    richer: 'It is belonging as something lived in the body and in relationship, not just membership on paper.',
    use: 'Use it for social belonging, safe recognition, and the feeling of being rightly placed among people.',
    not_for: 'Do not use it for official membership, bureaucratic inclusion, or simply being present somewhere.',
    example: 'She felt meras only when her own name could be spoken there without caution.',
    plain_english: 'She felt true belonging only when she could be herself there.',
  },
  {
    word: 'naerith',
    vaelinya_form: 'naerith',
    meaning: 'lived memory-trace',
    pronunciation: 'NAIR-ith',
    pronunciation_ipa: '/ˈneə.rɪθ/',
    what: 'A lived or felt trace of what has been experienced.',
    richer: 'It is memory that still moves through a person, place, body, or atmosphere.',
    use: 'Use it for a song, voice, loss, joy, meeting, room, or place that still carries what happened there.',
    not_for: 'Do not use it for factual recall alone, records, technical memory, or ordinary skill-memory.',
    example: 'The hall still held a naerith of their singing after the candles had gone out.',
    plain_english: 'The hall still carried a living trace of their singing after the candles were out.',
  },
  {
    word: 'orivai',
    vaelinya_form: 'orivai',
    meaning: 'meaningful return',
    pronunciation: 'OR-ih-vye',
    pronunciation_ipa: '/ˈɒr.ɪ.vaɪ/',
    what: 'A return that restores place, relation, or selfhood.',
    richer: 'It is coming back in a way that matters, especially after absence.',
    use: 'Use it for homecoming, restored relation, returning to a person, or coming back to a truer state of self.',
    not_for: 'Do not use it for routine travel, object routing, simple repetition, or neutral movement back.',
    example: 'At the old gate, her orivai felt less like arrival than being received again by her own life.',
    plain_english: 'At the old gate, her return felt like being welcomed back into her life.',
  },
  {
    word: 'eirav',
    vaelinya_form: 'eirav',
    meaning: 'meaningful arrival',
    pronunciation: 'EYE-rav',
    pronunciation_ipa: '/ˈaɪ.ræv/',
    what: 'An arrival that changes the emotional or social field because the one arriving matters.',
    richer: 'It is arrival with weight. The room changes because this person has entered it.',
    use: 'Use it for a first entrance or arrival that alters attention, feeling, atmosphere, or relation.',
    not_for: 'Do not use it for transport timing, packages, neutral scheduling, or return after absence.',
    example: 'Her eirav changed the whole table before she had said a word.',
    plain_english: 'Her arrival changed the whole mood of the table before she spoke.',
  },
];
---
<BaseLayout title="Lexicon" description="Five first Vaelinya words for home, belonging, memory, return, and arrival.">
  <section class="page-section lexicon-page">
    <p class="eyebrow">Language</p>
    <h1>Vaelinya words</h1>
    <p class="lede">Start with five small words. Each one names something felt: home-place, belonging, memory, return, or arrival.</p>
    <p>These are public Vaelinya words, not the whole grammar. Learn them as doorway words first.</p>

    <div class="lexicon-list">
      {words.map((entry) => (
        <article class="lexicon-entry">
          <header class="lexicon-entry-header">
            <h2>{entry.word}</h2>
            <p>{entry.meaning}</p>
          </header>

          <dl class="lexicon-fields">
            <div><dt>Vaelinya form</dt><dd>{entry.vaelinya_form}</dd></div>
            <div><dt>Pronunciation</dt><dd>{entry.pronunciation}</dd></div>
            <div><dt>IPA</dt><dd>{entry.pronunciation_ipa}</dd></div>
            <div class="wide-field"><dt>Meaning</dt><dd>{entry.what} {entry.richer}</dd></div>
            <div class="wide-field"><dt>Use it when</dt><dd>{entry.use}</dd></div>
            <div class="wide-field"><dt>Example</dt><dd>{entry.example}</dd></div>
            <div class="wide-field"><dt>Plain English</dt><dd>{entry.plain_english}</dd></div>
          </dl>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
