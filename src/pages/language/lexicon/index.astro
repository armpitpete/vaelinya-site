---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';

const order = [
  'aelok',
  'meras',
  'naerith',
  'orivai',
  'eirav',
  'siral',
  'sarek',
  'navak',
  'noras',
  'ismak',
  'threnai',
];

const entries = await getCollection('lexicon', ({ data }) => data.status === 'public');
const byWord = Object.fromEntries(entries.map(({ data }) => [data.word, data]));
const words = order.map((word) => byWord[word]).filter(Boolean);
---

<BaseLayout title="Lexicon" description="First public Vaelinya words.">
  <section class="page-section lexicon-page">
    <p class="eyebrow">Language</p>
    <h1>Vaelinya words</h1>
    <p class="lede">Start with the first public words. These are doorway words, not the whole grammar.</p>

    <section class="lexicon-index" aria-labelledby="word-index">
      <div class="lexicon-index-header">
        <h2 id="word-index">Word index</h2>
        <p>Jump to a word.</p>
      </div>

      <div class="lexicon-index-links">
        {words.map((entry) => (
          <a class="lexicon-chip" href={`#word-${entry.word}`}>
            <strong>{entry.word}</strong>
            <span>{entry.meaning}</span>
          </a>
        ))}
      </div>
    </section>

    <div class="lexicon-list">
      {words.map((entry) => (
        <article id={`word-${entry.word}`} class="lexicon-entry">
          <header class="lexicon-entry-header">
            <h3>{entry.word}</h3>
            <p>{entry.meaning}</p>
          </header>

          <dl class="lexicon-fields">
            <div>
              <dt>Vaelinya form</dt>
              <dd>{entry.vaelinya_form}</dd>
            </div>

            <div>
              <dt>Pronunciation</dt>
              <dd>{entry.pronunciation}</dd>
            </div>

            <div>
              <dt>IPA</dt>
              <dd>{entry.pronunciation_ipa}</dd>
            </div>

            <div class="wide-field">
              <dt>Meaning</dt>
              <dd>{entry.what}{entry.richer ? ` ${entry.richer}` : ''}</dd>
            </div>

            <div class="wide-field">
              <dt>Use it when</dt>
              <dd>{entry.use}</dd>
            </div>

            <div class="wide-field">
              <dt>Example</dt>
              <dd>{entry.example}</dd>
            </div>

            <div class="wide-field">
              <dt>Plain English</dt>
              <dd>{entry.plain_english}</dd>
            </div>
          </dl>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .lexicon-index {
    margin-top: 1.25rem;
    padding: clamp(1rem, 3vw, 1.25rem);
    background: rgba(255, 248, 232, 0.68);
    border: 1px solid rgba(31, 23, 48, 0.14);
    border-radius: 1.1rem;
  }

  .lexicon-index-header h2 {
    margin: 0;
    font-size: clamp(1.35rem, 4vw, 1.9rem);
    line-height: 1.1;
  }

  .lexicon-index-header p {
    margin: 0.35rem 0 0;
  }

  .lexicon-index-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 1rem;
  }

  .lexicon-chip {
    display: inline-flex;
    align-items: baseline;
    gap: 0.35rem;
    max-width: 100%;
    padding: 0.35rem 0.55rem;
    border-radius: 999px;
    background: rgba(255, 241, 199, 0.92);
    border: 1px solid rgba(31, 23, 48, 0.12);
    text-decoration: none;
    line-height: 1.2;
  }

  .lexicon-chip strong,
  .lexicon-chip span {
    overflow-wrap: anywhere;
  }

  .lexicon-chip span {
    font-size: 0.82rem;
    opacity: 0.78;
  }

  .lexicon-entry {
    scroll-margin-top: 1rem;
  }

  .lexicon-entry-header h3 {
    margin: 0;
    overflow-wrap: anywhere;
    font-size: clamp(1.45rem, 5vw, 2.2rem);
    line-height: 1.05;
  }

  @media (max-width: 520px) {
    .lexicon-chip {
      align-items: flex-start;
      flex-direction: column;
      gap: 0.08rem;
      border-radius: 0.75rem;
    }
  }
</style>
