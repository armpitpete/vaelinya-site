---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const words = [
  {
    word: 'NAVAN',
    meaning: 'Remember.',
    pronunciation: 'NAH-van',
    pronunciation_ipa: '/ˈnɑːvæn/',
    notes: 'A memory-word. It can carry the sense of remembering, carrying truth forward, and returning to what must not be lost.',
  },
  {
    word: 'Rimaeri',
    meaning: 'The people of the Rim.',
    pronunciation: 'rih-MAIR-ee',
    pronunciation_ipa: '/rɪˈmɛəri/',
    notes: 'The name used among the people themselves. Outsiders may call them Rimmers.',
  },
  {
    word: 'halaphalendrael',
    meaning: 'A stable public Vaelinyan name-word awaiting fuller context.',
    pronunciation: 'ha-la-pha-len-dra-el',
    pronunciation_ipa: '/hælæphælɛndræɛl/',
    notes: 'Included as a pronunciation anchor because its sound-form is stable.',
  },
];
---
<BaseLayout title="Lexicon" description="A growing public lexicon for Vaelinya.">
  <section class="page-section">
    <p class="eyebrow">Language</p>
    <h1>Lexicon</h1>
    <p class="lede">The public lexicon gathers stable Vaelinyan words in small, readable entries. Each entry gives meaning, pronunciation, pronunciation_ipa, and notes.</p>
    <div class="lexicon-list">
      {words.map((entry) => (
        <article class="lexicon-entry">
          <h2>{entry.word}</h2>
          <dl>
            <div>
              <dt>Meaning</dt>
              <dd>{entry.meaning}</dd>
            </div>
            <div>
              <dt>Pronunciation</dt>
              <dd>{entry.pronunciation}</dd>
            </div>
            <div>
              <dt>pronunciation_ipa</dt>
              <dd>{entry.pronunciation_ipa}</dd>
            </div>
            <div>
              <dt>Notes</dt>
              <dd>{entry.notes}</dd>
            </div>
          </dl>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
