import BaseLayout from '../../../layouts/BaseLayout.astro';
---
<BaseLayout title="Language Reference" description="A lived public guide to how Vaelinya language is approached.">
  <section class="page-section">
    <p class="eyebrow">Language</p>
    <h1>Language Reference</h1>
    <p class="lede">Vaelinya language is meant to be learned slowly, clearly, and with meaning close to the reader.</p>
    <div class="link-list">
      <a href="/language/lexicon/">Open the lexicon</a>
      <a href="/world/rimaeri/">See the people</a>
    </div>
    <p>Public language pages grow through stable sound, meaning, names, pronunciation, and usage rather than scattered fragments.</p>
    <p>Language in Vaelinya belongs to people, memory, place, and relation. A word may carry social meaning, cultural memory, or a practical way of seeing the world.</p>
    <ul>
      <li>Meaning first</li>
      <li>Pronunciation next</li>
      <li>pronunciation_ipa where stable</li>
      <li>Context before complexity</li>
      <li>Learn in small clear steps</li>
    </ul>
  </section>
</BaseLayout>
